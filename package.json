{
  "name": "econos",
  "version": "0.153.0",
  "private": true,
  "description": "A-Level economics revision — bite-sized topics around the frameworks examiners reward.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173 --host 127.0.0.1",
    "lint:repo": "./scripts/lint.sh",
    "lint:js": "eslint 'js/**/*.js' --max-warnings=0",
    "lint:charts": "node scripts/lint-charts.mjs",
    "lint:cards": "node scripts/lint-card-lengths.mjs",
    "lint:tokens": "node scripts/lint-tokens.mjs",
    "lint": "npm run lint:repo && npm run lint:js && npm run lint:charts && npm run lint:cards",
    "format": "prettier --write 'js/**/*.js' '*.html' '*.json' '*.md'",
    "format:check": "prettier --check 'js/**/*.js' '*.html' '*.json' '*.md'",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "audit:diagrams": "node scripts/audit-diagrams.mjs",
    "export:content": "node scripts/export-content.mjs",
    "fetch:symbols": "node scripts/fetch-symbols.mjs",
    "render:charts": "node scripts/render-charts.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.45.0",
    "eslint": "^8.57.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.2.0",
    "markdown-it-container": "^4.0.0",
    "prettier": "^3.2.5",
    "vite": "^6.4.2",
    "vite-plugin-static-copy": "^2.3.2",
    "vitest": "^4.1.7"
  }
}
