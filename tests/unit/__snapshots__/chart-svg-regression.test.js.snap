exports[`chart SVG regression > ppf-card1.js renders unchanged SVG markup > ECONOS_PPF_CARD1_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="ppf-svg" viewBox="0 -16 440 376" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂, PPF₃ curves and A, B, C, D, E, F, G, H points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂, PPF₃. Points: A at (0.46, 0.41), B at (0.24, 0.26), C at (0.67, 0.57), D at (0.25, 0.57), E at (0.60, 0.20), F at (0.46, 0.41), G at (0.34, 0.52), H at (0.23, 0.26).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="44" width="350" height="276"/></clipPath><style>.econos-chart-legends .layer-legend-base,.econos-chart-legends .layer-legend-extension,.econos-chart-legends .layer-legend-shift,.econos-chart-legends .layer-legend-efficiency{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-base .econos-chart-legends .layer-legend-base{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-extension .econos-chart-legends .layer-legend-extension{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-shift .econos-chart-legends .layer-legend-shift{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-efficiency .econos-chart-legends .layer-legend-efficiency{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 