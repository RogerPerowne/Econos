wn"><text x="215" y="417.85" font-size="13" fill="#DC2626" text-anchor="middle" font-weight="700" font-style="italic">Q₂</text></g><g class="layer-both-up"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Demand and supply both increase → Q rises, P ambiguous</text></g><g class="layer-d-up-s-down"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Demand rises, supply falls → P rises, Q ambiguous</text></g><g class="layer-d-down-s-up"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Demand falls, supply rises → P falls, Q ambiguous</text></g><g class="layer-both-down"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Demand and supply both decrease → Q falls, P ambiguous</text></g><g class="layer-both-up"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">D AND S BOTH RISE</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">D shifts right · S shifts right.</text><text x="620" y="132" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">PREDICTABLE</text><text x="620" y="163" font-size="13" font-weight="700" fill="#059669">Quantity   RISES ↑</text><text x="620" y="192" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">AMBIGUOUS</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">Price depends on which</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">shift is larger.</text></g></g><g class="layer-d-up-s-down"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">D RIGHT · S LEFT</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">D shifts right (more buyers).</text><text x="620" y="123" font-size="13" font-weight="600" fill="#0F172A">S shifts left (less production).</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">PREDICTABLE</text><text x="620" y="183" font-size="13" font-weight="700" fill="#059669">Price   RISES ↑</text><text x="620" y="212" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">AMBIGUOUS</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">Quantity could go either way.</text></g></g><g class="layer-d-down-s-up"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">D LEFT · S RIGHT</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">D shifts left (fewer buyers).</text><text x="620" y="123" font-size="13" font-weight="600" fill="#0F172A">S shifts right (more production).</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">PREDICTABLE</text><text x="620" y="183" font-size="13" font-weight="700" fill="#DC2626">Price   FALLS ↓</text><text x="620" y="212" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">AMBIGUOUS</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">Quantity could go either way.</text></g></g><g class="layer-both-down"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">D AND S BOTH FALL</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">D shifts left · S shifts left.</text><text x="620" y="132" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">PREDICTABLE</text><text x="620" y="163" font-size="13" font-weight="700" fill="#DC2626">Quantity   FALLS ↓</text><text x="620" y="192" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">AMBIGUOUS</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">Price depends on which</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">shift is larger.</text></g>