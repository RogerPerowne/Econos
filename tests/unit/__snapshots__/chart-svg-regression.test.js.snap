exports[`chart SVG regression > stagflation-phillips.js renders unchanged SVG markup > ECONOS_STAGFLATION_PHILLIPS_SPEC 1`] = `"<svg class="stagflation-phillips-svg" viewBox="0 -16 640 356" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with SRPC₁, LRPC, SRPC₂, SRPC₃ curves and A, B, C, S points</title><desc id="econos-chart-desc">Unemployment (U %) on x-axis, Inflation (π %) on y-axis. Curves: SRPC₁, LRPC, SRPC₂, SRPC₃. Points: A at (0.43, 0.54), B at (0.24, 0.69), C at (0.43, 0.73), S at (0.63, 0.61).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="20" width="540" height="260"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-3{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-3 .idl-3{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="640" height="356" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="280" x2="60" y2="15" stroke="#334155" stroke-width="2"/><polygon points="60,10 56,22 64,22" fill="#334155"/><line x1="60" y1="280" x2="605" y2="280" stroke="#334155" stroke-width="2"/><polygon points="610,280 598,276 598,284" fill="#334155"/><text x="50" y="294" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="5" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Inflation (π %)</text><text x="610" y="298" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Unemployment (U %)</text></g></g><g class="idl-1"><path d="M 90.2,60.0L 540.1,240.0" fill="none" stroke="#2563EB" stroke-width="2.6" clip-path="url(#econos-chart-clip)"/><text x="546.06" y="243.96" text-anchor="start" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">SRPC₁</text></g><g class="idl-2"><path d="M 90.2,60.0L 540.1,240.0" fill="none" stroke="#475569" stroke-width="2" stroke-dasharray="5 4" opacity="0.6" clip-path="url(#econos-chart-clip)"/><text x="546.06" y="243.96" text-anchor="start" font-size="13" font-weight="700" fill="#0F172A" dominant-baseline="middle">SRPC₁</text></g><g class="idl-2"><path d="M 290.0,280.0L 290.0,20.0" fill="none" stroke="#7C3AED" stroke-width="2.4" stroke-dasharray="6 4" clip-path="url(#econos-chart-clip)"/><text x="298.03999999999996" y="18" text-anchor="start" font-size="13" font-weight="700" fill="#7D23CB" dominant-baseline="middle">LRPC</text></g><g class="idl-2"><path d="M 90.2,10.1L 540.1,190.0" fill="none" stroke="#2563EB" stroke-width="2.6" clip-path="url(#econos-chart-clip)"/><text x="546.06" y="194.04000000000002" text-anchor="start" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">SRPC₂</text></g><g class="idl-3"><path d="M 90.2,60.0L 540.1,240.0" fill="none" stroke="#475569" stroke-width="2" stroke-dasharray="5 4" opacity="0.6" clip-path="url(#econos-chart-clip)"/><text x="546.06" y="243.96" text-anchor="start" font-size="13" font-weight="700" fill="#0F172A" dominant-baseline="middle">SRPC₁</text></g><g class="idl-3"><path d="M 90.2,-3.9L 540.1,176.0" fill="none" stroke="#DC2626" stroke-width="2.6" clip-path="url(#econos-chart-clip)"/><text x="546.06" y="180" text-anchor="start" font-size="13" font-weight="700" fill="#DC2626" dominant-baseline="middle">SRPC₃</text></g><g class="idl-2"><path d="M 281.94,136.22 L 198.24,103.98000000000002" fill="none" stroke="#D97706" stroke-width="1.8" marker-end="url(#econos-arrow-amber)"/></g><g class="idl-2"><path d="M 198.24,100.08000000000001 L 281.94,93.84" fill="none" stroke="#059669" stroke-width="1.8" marker-end="url(#econos-arrow-green)"/></g><g class="idl-3"><path d="M 300.84000000000003,145.32 L 389.4,114.9" fill="none" stroke="#DC2626" stroke-width="2" marker-end="url(#econos-arrow-red)"/></g><g class="idl-1"><line x1="60" y1="140.12" x2="290.03999999999996" y2="140.12" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/><line x1="290.03999999999996" y1="280" x2="290.03999999999996" y2="140.12" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="144.12" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">π₀</text><text x="290.03999999999996" y="297" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">U_N</text><g class="chart-point"><circle cx="290.03999999999996" cy="140.12" r="6" fill="#FFFFFF" stroke="#475569" stroke-width="2.5"/><text x="302.03999999999996" y="136.12" font-size="13" font-weight="700" fill="#0F172A" text-anchor="start" dominant-baseline="middle">A</text></g></g><g class="idl-2"><g class="chart-point"><circle cx="290.03999999999996" cy="140.12" r="5" fill="#FFFFFF" stroke="#475569" stroke-width="2.5"/><text x="302.03999999999996" y="136.12" font-size="13" font-weight="700" fill="#0F172A" text-anchor="start" dominant-baseline="middle">A</text></g></g><g class="idl-2"><line x1="60" y1="100.08000000000001" x2="190.14" y2="100.08000000000001" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="190.14" y1="280" x2="190.14" y2="100.08000000000001" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="190.14" y="297" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">U₁</text><g class="chart-point"><circle cx="190.14" cy="100.08000000000001" r="6" fill="#FFFFFF" stroke="#D97706" stroke-width="2.5"/><text x="178.14" y="96.08000000000001" font-size="13" font-weight="700" fill="#D97706" text-anchor="end" dominant-baseline="middle">B</text></g></g><g class="idl-2"><line x1="60" y1="89.94" x2="290.03999999999996" y2="89.94" stroke="#059669" stroke-width="1" stroke-dasharray="4 3"/><line x1="290.03999999999996" y1="280" x2="290.03999999999996" y2="89.94" stroke="#059669" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="93.94" font-size="12" font-weight="700" fill="#059669" text-anchor="middle">π_C</text><g class="chart-point"><circle cx="290.03999999999996" cy="89.94" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="302.03999999999996" y="85.94" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">C</text></g></g><g class="idl-3"><g class="chart-point"><circle cx="290.03999999999996" cy="140.12" r="5" fill="#FFFFFF" stroke="#475569" stroke-width="2.5"/><text x="302.03999999999996" y="136.12" font-size="13" font-weight="700" fill="#0F172A" te