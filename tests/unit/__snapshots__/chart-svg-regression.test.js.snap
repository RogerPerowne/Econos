exports[`chart SVG regression > ad-shift-perspectives.js renders unchanged SVG markup > ECONOS_AD_SHIFT_PERSPECTIVES_SPEC 1`] = `"<svg class="ad-shift-perspectives-svg" viewBox="0 0 440 340" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with AD₁, AD₂, LRAS, AS curves and E₁, E₂, E₁, E₂ points</title><desc id="econos-chart-desc">Real output (Y) on x-axis, Price level (P) on y-axis. Curves: AD₁, AD₂, LRAS, AS. Points: E₁ at (0.65, 0.25), E₂ at (0.65, 0.37), E₁ at (0.60, 0.30), E₂ at (0.62, 0.40).</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="35" width="360" height="254"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-1,.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><style>.perspective-classical,.perspective-keynesian{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.chart-classical .perspective-classical{opacity:1;visibility:visible;transition:opacity .35s ease-out}.chart-keynesian .perspective-keynesian{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="asp-arr-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#3B82F6"/></marker><marker id="asp-arr-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="asp-arr-grey" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#94A3B8"/></marker></defs><rect width="440" height="340