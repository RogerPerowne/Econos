exports[`chart SVG regression > demand-card1.js renders unchanged SVG markup > ECONOS_DEMAND_CARD1_SPEC 1`] = `"<svg class="demand-law-svg" viewBox="0 0 700 400" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D curves and A (£12, 10), B (£8, 20), C (£4, 30) points</title><desc id="econos-chart-desc">Quantity on x-axis, Price (£) on y-axis. Curves: D. Points: A (£12, 10) at (0.24, 0.92), B (£8, 20) at (0.47, 0.61), C (£4, 30) at (0.71, 0.30).</desc><defs><clipPath id="econos-chart-clip"><rect x="90" y="40" width="520" height="280"/></clipPath></defs><rect width="700" height="400" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="90" y1="320" x2="90" y2="35" stroke="#334155" stroke-width="2"/><polygon points="90,30 86,42 94,42" fill="#334155"/><line x1="90" y1="320" x2="615" y2="320" stroke="#334155" stroke-width="2"/><polygon points="620,320 608,316 608,324" fill="#334155"/><text x="80" y="334" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="90" y="25" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price (£)</text><text x="620" y="338" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Quantity</text></g></g><path d="M 163.8,29.4L 568.9,310.5" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="578.9200000000001" y="310.48" font-size="13" font-weight="700" fill="#059669">D</text><path d="M 90,63.80000000000001 L 213.24,63.80000000000001" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 90,149.20000000000002 L 336.48,149.20000000000002" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 90,234.60000000000002 L 459.71999999999997,234.60000000000002" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 213.24,63.80000000000001 L 213.24,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 336.48,149.20000000000002 L 336.48,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 459.71999999999997,234.60000000000002 L 459.71999999999997,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><g class="chart-point"><circle cx="213.24" cy="63.80000000000001" r="6" fill="#059669"/><text x="223.24" y="47.80000000000001" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">A (£12, 10)</text></g><g class="chart-point"><circle cx="336.48" cy="149.20000000000002" r="6" fill="#059669"/><text x="346.48" y="133.20000000000002" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">B (£8, 20)</text></g><g class="chart-point"><circle cx="459.71999999999997" cy="234.60000000000002" r="6" fill="#059669"/><text x="469.71999999999997" y="218.60000000000002" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">C (£4, 30)</text></g><text x="80.64" y="63.80000000000001" font-size="13" fill="#0F172A" text-anchor="end">12</text><text x="80.64" y="149.20000000000002" font-size="13" fill="#0F172A" text-anchor="end">8</text><text x="80.64" y="234.60000000000002" font-size="13" fill="#0F172A" text-anchor="end">4</text><text x="213.24" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">10</text><text x="336.48" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">20</text><text x="459.71999999999997" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">30</text><text x="350" y="364.8" font-size="13" fill="#0F172A" text-anchor="middle" font-style="italic">As price falls, quantity increases – shown by a downward-sloping demand curve.</text></svg>"`;

exports[`chart SVG regression > demand-card2.js renders unchanged SVG markup > ECONOS_DEMAND_CARD2_SPEC 1`] = `"<svg class="demand-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D₁, D₀, D₂ curves</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D₁, D₀, D₂.</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath><marker id="dm-amber-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#D97706"/></marker><marker id="dm-amber-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#D97706"/></marker><marker id="dm-green-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#059669"/></marker><marker id="dm-red-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#DC2626"/></marker></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="595" y1="16" x2="595" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-demand-base"><path d="M 100.0,90.1L 490.0,370.0" fill="none" stroke="#2563EB" stroke-width="3.5" clip-path="url(#econos-chart-clip)"/><text x="496" y="364.012" font-size="13" font-weight="700" fill="#2563EB">D₁</text></g><g class="layer-shift"><path d="M 100.0,90.1L 490.0,370.0" fill="none" stroke="#2563EB" stroke-width="2" stroke-dasharray="9 5" opacity="0.55" clip-path="url(#econos-chart-clip)"/></g><g class="layer-shift"><path d="M 30.0,90.1L 420.0,370.0" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="428" y="364.012" font-size="13" font-weight="700" fill="#2563EB">D₀</text></g><g class="layer-shift"><path d="M 170.0,90.1L 560.0,370.0" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="568" y="364.012" font-size="13" font-weight="700" fill="#2563EB">D₂</text></g><g class="layer-e1"><path d="M 60,230.068 L 295,230.068" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-e1"><path d="M 295,230.068 L 295,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 60,170.09199999999998 L 212,170.09199999999998" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 212,170.09199999999998 L 212,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 60,295.04200000000003 L 385,295.04200000000003" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 385,295.04200000000003 L 385,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 230.5,161.52399999999997 L 388.5,275.764" fill="none" stroke="#D97706" stroke-width="2.5" marker-start="url(#dm-amber-start)" marker-end="url(#dm-amber-end)"/></g><g class="layer-shift"><path d="M 225,246.49 L 225,400" fill="none" stroke="#DC2626" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-shift"><path d="M 365,246.49 L 365,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-shift"><path d="M 300,230.068 L 361,230.068" fill="none" stroke="#059669" stroke-width="3.5" marker-end="url(#dm-green-end)"/></g><g class="layer-shift"><path d="M 290,230.068 L 229,230.068" fill="none" stroke="#DC2626" stroke-width="3.5" marker-end="url(#dm-red-end)"/></g><g class="layer-e1"><g class="chart-point"><circle cx="295" cy="230.068" r="6" fill="#FFFFFF" stroke="#2563EB" stroke-width="2.5"/></g></g><g class="layer-extension"><g class="chart-point"><circle cx="212" cy="170.09199999999998" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-extension"><g class="chart-point"><circle cx="385" cy="295.04200000000003" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="225" cy="230.068" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="295" cy="230.068" r="4" fill="#475569"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="365" cy="230.068" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-legend-base"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#2563EB"/></g></g><g class="layer-extension"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#D97706"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#059669"/></g></g><g class="layer-legend-base"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Demand slopes downward · inverse price-quantity relationship</text></g><g class="layer-extension"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Price changes → slide ALONG the demand curve</text></g><g class="layer-shift"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Non-price factors → SHIFT the whole demand curve</text></g><g class="layer-e1"><text x="46" y="230.068" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P₁</text></g><g class="layer-e1"><text x="295" y="417.85" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q₁</text></g><g class="layer-extension"><text x="46" y="170.09199999999998" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P₂</text></g><g class="layer-extension"><text x="212" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q₂</text></g><g class="layer-extension"><text x="46" y="295.04200000000003" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P₃</text></g><g class="layer-extension"><text x="385" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q₃</text></g><g class="layer-extension"><text x="220" y="157.95399999999998" font-size="12" fill="#DC2626" text-anchor="start" font-weight="700">contraction</text></g><g class="layer-extension"><text x="340" y="315.034" font-size="12" fill="#059669" text-anchor="start" font-weight="700">extension</text></g><g class="layer-shift"><text x="500" y="370.012" font-size="13" fill="#2563EB" text-anchor="start" font-weight="700" opacity="0.55">D₁</text></g><g class="layer-shift"><text x="225" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q₀</text></g><g class="layer-shift"><text x="295" y="417.85" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q₁</text></g><g class="layer-shift"><text x="365" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q₂</text></g><g class="layer-legend-base"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">THE DEMAND CURVE</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">Downward sloping: higher</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">prices → less demanded.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">TWO REASONS</text><text x="620" y="183" font-size="13" font-weight="700" fill="#0F172A">① Substitution effect:</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">good becomes expensive relative</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">to substitutes</text><text x="620" y="243" font-size="13" font-weight="700" fill="#0F172A">② Income effect:</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">real purchasing power falls as</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">price rises</text><text x="620" y="312" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">AT EQUILIBRIUM</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">Quantity demanded Q₁ at price P₁.</text></g></g><g class="layer-legend-extension"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">MOVEMENT ALONG CURVE</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">Only a price change causes this –</text><text x="620" y="123" font-size="13" font-weight="600" fill="#0F172A">the curve itself stays fixed.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">CONTRACTION (E₂)</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">P rises → Q falls</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">Move up the curve</text><text x="620" y="232" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">EXTENSION (E₃)</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">P falls → Q rises</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">Move down the curve</text><text x="620" y="312" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">EXAM LANGUAGE</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">Say "quantity demanded rises/falls,"</text><text x="620" y="363" font-size="13" font-weight="600" fill="#0F172A">not "demand rises/falls."</text></g></g><g class="layer-legend-shift"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">SHIFT OF DEMAND</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">A non-price determinant changes –</text><text x="620" y="123" font-size="13" font-weight="600" fill="#0F172A">the whole curve moves.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">D₂ – RIGHT (INCREASE)</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">↑ income, ↑ tastes,</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">↑ substitute price</text><text x="620" y="232" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">D₀ – LEFT (DECREASE)</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">↓ income, ↓ tastes,</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">↑ complement price</text><text x="620" y="312" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">REMEMBER</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">Q changes at EVERY price –</text><text x="620" y="363" font-size="13" font-weight="600" fill="#0F172A">not just P₁.</text></g></g></svg>"`;

exports[`chart SVG regression > demand-card4.js renders unchanged SVG markup > ECONOS_DEMAND_CARD4_SPEC 1`] = `"<svg class="demand-cs-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D curves</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D.</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="515" height="357"/></clipPath></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="608" y1="16" x2="608" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="580" y2="400" stroke="#334155" stroke-width="2"/><polygon points="585,400 573,396 573,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="585" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-cs"><polygon points="60,65.13400000000001 60,225.07 318.015,225.07" fill="#D1FAE5" opacity="0.85"/></g><g class="layer-pfall-cs"><polygon points="60,65.13400000000001 60,290.044 423.075,290.044" fill="#D1FAE5" opacity="0.85"/></g><g class="layer-demand"><path d="M 60.0,65.1L 560.1,375.0" fill="none" stroke="#059669" stroke-width="3.5" clip-path="url(#econos-chart-clip)"/><text x="570.065" y="375.01" font-size="13" font-weight="700" fill="#059669">D</text></g><g class="layer-eq"><path d="M 60,225.07 L 318.015,225.07" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-eq"><path d="M 318.015,225.07 L 318.015,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-pfall"><path d="M 60,225.07 L 423.075,225.07" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="4 4"/></g><g class="layer-pfall"><path d="M 318.015,225.07 L 318.015,400" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="4 4"/></g><g class="layer-pfall"><path d="M 60,290.044 L 423.075,290.044" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-pfall"><path d="M 423.075,290.044 L 423.075,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-eq"><g class="chart-point"><circle cx="318.015" cy="225.07" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-pfall"><g class="chart-point"><circle cx="423.075" cy="290.044" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-eq"><text x="44.55" y="225.07" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P*</text></g><g class="layer-eq"><text x="318.015" y="416.065" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-cs-label"><text x="137.765" y="170.09199999999998" font-size="18" fill="#059669" text-anchor="middle" font-weight="700">CS</text></g><g class="layer-pfall"><text x="44.55" y="225.07" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P*</text></g><g class="layer-pfall"><text x="318.015" y="416.065" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-pfall"><text x="44.55" y="290.044" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P₂</text></g><g class="layer-pfall"><text x="423.075" y="416.065" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q₂</text></g><g class="layer-pfall"><text x="154.76" y="210.076" font-size="18" fill="#059669" text-anchor="middle" font-weight="700">CS</text></g><text x="626.5" y="32.289999999999964" font-size="12" fill="#0F172A" text-anchor="start" font-weight="700">TAP A STEP TO BUILD THE DIAGRAM</text><g class="layer-legend-base"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#475569" letter-spacing="1.5">THE DEMAND CURVE</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">Each point on D shows the</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">maximum a buyer would pay.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">WILLINGNESS TO PAY</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">At Q=1, a buyer might pay £100.</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">At Q=10, they'd only pay £40.</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">Diminishing marginal utility.</text><text x="620" y="252" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">THE MARKET PRICE</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">Everyone pays the same market</text><text x="620" y="303" font-size="13" font-weight="600" fill="#0F172A">price P* – but those with higher</text><text x="620" y="323" font-size="13" font-weight="600" fill="#0F172A">WTP get a bonus. Tap to reveal it.</text></g></g><g class="layer-cs-label"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">CONSUMER SURPLUS</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">The green triangle: buyers paid</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">P* but were willing to pay more.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">THREE VERTICES</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">① P-axis: where D meets the price</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">   axis (max willingness to pay)</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">② (Q*, P*): equilibrium point</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">③ (0, P*): market price on P-axis</text><text x="620" y="272" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">FORMULA</text><text x="620" y="303" font-size="13" font-weight="600" fill="#0F172A">CS = ½ × Q* × (max WTP − P*)</text><text x="620" y="332" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">KEY POINT</text><text x="620" y="363" font-size="13" font-weight="600" fill="#0F172A">CS is maximised at the free-market</text><text x="620" y="383" font-size="13" font-weight="600" fill="#0F172A">equilibrium. Any distortion shrinks it.</text></g></g><g class="layer-pfall"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">PRICE FALLS → CS EXPANDS</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">When price drops from P* to P₂,</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">consumer surplus gets bigger.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">TWO GAINS</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">① Existing buyers save (P*−P₂) on</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">   every unit – the rectangle widens</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">② New buyers enter who weren't</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">   willing to pay P* – the triangle</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">   extends to Q₂</text><text x="620" y="292" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">REVERSE: PRICE RISES</text><text x="620" y="323" font-size="13" font-weight="600" fill="#0F172A">CS shrinks – buyers either pay</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">more or leave the market entirely.</text><text x="620" y="372" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">EXAM POINT</text><text x="620" y="403" font-size="13" font-weight="600" fill="#0F172A">A tax raises consumer price → CS</text><text x="620" y="423" font-size="13" font-weight="600" fill="#0F172A">falls – part lost, part to govt revenue.</text></g></g></svg>"`;

exports[`chart SVG regression > demand-card7.js renders unchanged SVG markup > ECONOS_DEMAND_CARD7_SPEC 1`] = `"<svg class="demand-schedule-svg" viewBox="0 0 700 400" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D curves and A (12, 10), B (10, 20), C (8, 30), D (6, 40), E (4, 50) points</title><desc id="econos-chart-desc">Quantity on x-axis, Price (£) on y-axis. Curves: D. Points: A (12, 10) at (0.19, 0.87), B (10, 20) at (0.39, 0.68), C (8, 30) at (0.58, 0.49), D (6, 40) at (0.77, 0.30), E (4, 50) at (0.96, 0.11).</desc><defs><clipPath id="econos-chart-clip"><rect x="90" y="40" width="520" height="280"/></clipPath></defs><rect width="700" height="400" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="90" y1="320" x2="90" y2="35" stroke="#334155" stroke-width="2"/><polygon points="90,30 86,42 94,42" fill="#334155"/><line x1="90" y1="320" x2="615" y2="320" stroke="#334155" stroke-width="2"/><polygon points="620,320 608,316 608,324" fill="#334155"/><text x="80" y="334" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="90" y="25" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price (£)</text><text x="620" y="338" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Quantity</text></g></g><path d="M 139.9,49.0L 622.5,305.4" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="632.48" y="305.44" font-size="13" font-weight="700" fill="#059669">D</text><path d="M 90,75.56 L 190.36,75.56" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 90,128.76 L 290.72,128.76" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 90,182.24 L 390.56,182.24" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 90,235.44 L 490.92,235.44" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 90,288.92 L 591.28,288.92" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 190.36,75.56 L 190.36,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 290.72,128.76 L 290.72,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 390.56,182.24 L 390.56,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 490.92,235.44 L 490.92,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><path d="M 591.28,288.92 L 591.28,320" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="3 3"/><g class="chart-point"><circle cx="190.36" cy="75.56" r="6" fill="#059669"/><text x="200.36" y="59.56" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">A (12, 10)</text></g><g class="chart-point"><circle cx="290.72" cy="128.76" r="6" fill="#059669"/><text x="300.72" y="112.75999999999999" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">B (10, 20)</text></g><g class="chart-point"><circle cx="390.56" cy="182.24" r="6" fill="#059669"/><text x="400.56" y="166.24" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">C (8, 30)</text></g><g class="chart-point"><circle cx="490.92" cy="235.44" r="6" fill="#059669"/><text x="500.92" y="219.44" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">D (6, 40)</text></g><g class="chart-point"><circle cx="591.28" cy="288.92" r="6" fill="#059669"/><text x="581.28" y="310.92" font-size="13" font-weight="700" fill="#059669" text-anchor="end" dominant-baseline="middle">E (4, 50)</text></g><text x="80.64" y="75.56" font-size="13" fill="#0F172A" text-anchor="end">12</text><text x="80.64" y="128.76" font-size="13" fill="#0F172A" text-anchor="end">10</text><text x="80.64" y="182.24" font-size="13" fill="#0F172A" text-anchor="end">8</text><text x="80.64" y="235.44" font-size="13" fill="#0F172A" text-anchor="end">6</text><text x="80.64" y="288.92" font-size="13" fill="#0F172A" text-anchor="end">4</text><text x="190.36" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">10</text><text x="290.72" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">20</text><text x="390.56" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">30</text><text x="490.92" y="335.4" font-size="13" fill="#0F172A" text-anchor="middle">40</text></svg>"`;

exports[`chart SVG regression > discovered specs match the manifest > manifest 1`] = `
[
  "ad-movement-shift.js::ECONOS_AD_MOVEMENT_SHIFT_SPEC",
  "ad-shift-perspectives.js::ECONOS_AD_SHIFT_PERSPECTIVES_SPEC",
  "ad-slope.js::ECONOS_AD_SLOPE_SPEC",
  "allocative-efficiency.js::ECONOS_ALLOCATIVE_EFFICIENCY_SPEC",
  "cps-build-interactive.js::ECONOS_CPS_BUILD_SPEC",
  "cps-diagram.js::ECONOS_CPS_DIAGRAM_SPEC",
