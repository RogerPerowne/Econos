exports[`chart SVG regression > welfare-loss-diagram.js renders unchanged SVG markup > ECONOS_WELFARE_LOSS_DIAGRAM_SPEC 1`] = `"<svg class="welfare-loss-diagram-svg econos-chart--wide" viewBox="0 -16 720 336" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with MPB = D, MPC, MSC, MPB, MPC = S, MSB curves and E_m, E*, E* points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: MPB = D, MPC, MSC, MPB, MPC = S, MSB. Points: E_m at (0.52, 0.48), E* at (0.42, 0.57), E* at (0.61, 0.56).</desc><defs><clipPath id="econos-chart-clip-0"><rect x="50" y="28" width="280" height="254"/></clipPath><clipPath id="econos-chart-clip-1"><rect x="410" y="28" width="280" height="254"/></clipPath><clipPath id="econos-chart-clip"><rect x="50" y="28" width="280" height="254"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0