rker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="700" height="496" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="84" y1="412" x2="84" y2="35" stroke="#334155" stroke-width="2"/><polygon points="84,30 80,42 88,42" fill="#334155"/><line x1="84" y1="412" x2="623" y2="412" stroke="#334155" stroke-width="2"/><polygon points="628,412 616,408 616,416" fill="#334155"/><text x="74" y="426" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="84" y="25" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price</text><text x="628" y="430" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Quantity</text></g></g><path d="M 137.4,82.4L 586.0,378.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="593.96" y="374.148" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">D</text><path d="M 137.4,378.1L 586.0,82.4" fill="none" stroke="#D97706" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="593.96" y="78.40800000000002" font-size="13" font-weight="700" fill="#D97706" dominant-baseline="middle">S</text><g class="layer-e"><path d="M 84,229.72 L 361.68,229.72" fill="none" stroke="#475569" stroke-width="1.4" stroke-dasharray="5 4"/></g><g class="layer-e"><path d="M 361.68,229.72 L 361.68,412" fill="none" stroke="#475569" stroke-width="1.4" stroke-dasharray="5 4"/></g><g class="layer-e"><g class="chart-point"><circle cx="361.68" cy="229.72" r="6" fill="#475569"/><text x="373.68" y="220.72" font-size="13" font-weight="700" fill="#0F172A" text-anchor="start" dominant-baseline="middle">E</text></g></g><g class="layer-clear"><g class="chart-point"><circle cx="361.68" cy="229.72" r="11" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-e"><text x="7