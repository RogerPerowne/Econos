exports[`chart SVG regression > neg-externality-interactive.js renders unchanged SVG markup > ECONOS_NEG_EXTERNALITY_SPEC 1`] = `"<svg class="negext-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D = MSB, MPC, MSC curves and E_market, E* points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D = MSB, MPC, MSC. Points: E_market at (0.47, 0.48), E* at (0.36, 0.59).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="595" y1="16" x2="595" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-dwl"><polygon points="239,190.084 295,150.10000000000002 295,230.068" fill="#FEE2E2" opacity="0.75"/></g><g class="layer-base-curves"><path d="M 100.0,90.1L 490.0,370.0" fill="none" stroke="#D97706" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="498" y="374.012" font-size="13" font-weight="700" fill="#D97706">D = MSB</text></g><g class="layer-base-curves"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="498" y="86.12400000000002" font-size="13" font-weight="700" fill="#059669">MPC</text></g><g class="layer-msc"><path d="M 100.0,290.0L 490.0,10.2" fill="none" stroke="#2563EB" stroke-width="3" stroke-dasharray="9 5" clip-path="url(#econos-chart-clip)"/><text x="452" y="34.15599999999995" font-size="13" font-weight="700" fill="#2563EB">MSC</text></g><g class="layer-market-eq"><path d="M 60,230.068 L 295,230.068" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><path d="M 295,230.068 L 295,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-mec"><path d="M 400,75.13 L 400,155.09799999999998" fill="none" stroke="#7C3AED" stroke-width="3"/></g><g class="layer-optimal"><path d="M 60,190.084 L 239,190.084" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-optimal"><path d="M 239,190.084 L 239,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><g class="chart-point"><circle cx="295" cy="230.068" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/><text x="307" y="226.068" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">E_market</text></g></g><g class="layer-optimal"><g class="chart-point"><circle cx="239" cy="190.084" r="7" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="239" y="174.084" font-size="13" font-weight="700" fill="#059669" text-anchor="middle" dominant-baseline="middle">E*</text></g></g><g class="layer-legend-base"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#DC2626"/></g></g><g class="layer-legend-extension"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#7C3AED"/></g></g><g class="layer-legend-shift"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#059669"/></g></g><g class="layer-legend-efficiency"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#DC2626"/></g></g><g class="layer-market-eq"><text x="46" y="230.068" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P_m</text></g><g class="layer-market-eq"><text x="295" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q_m</text></g><g class="layer-mec"><text x="412.00000000000006" y="115.11399999999998" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">MEC</text></g><g class="layer-optimal"><text x="46" y="190.084" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P*</text></g><g class="layer-optimal"><text x="239" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-dwl"><text x="286.33333333333337" y="190.084" font-size="13" fill="#DC2626" text-anchor="middle" font-weight="700">DWL</text></g><g class="layer-legend-base"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Free market equilibrium: MPC = MSB</text></g><g class="layer-legend-extension"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Production imposes external costs → MSC sits above MPC</text></g><g class="layer-legend-shift"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Socially optimal output: where MSC = MSB</text></g><g class="layer-legend-efficiency"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Overproduction → deadweight welfare loss triangle</text></g><g class="layer-legend-base"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">FREE MARKET OUTCOME</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">Producers maximise profit at</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">MPC = MSB → equilibrium at</text><text x="620" y="136" font-size="13" font-weight="700" fill="#0F172A">(Q_m, P_m).</text><text x="620" y="165" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">WHAT EACH CURVE MEANS</text><text x="620" y="196" font-size="13" font-weight="700" fill="#D97706">D = MSB</text><text x="620" y="216" font-size="13" font-weight="600" fill="#0F172A">Marginal social benefit – value</text><text x="620" y="236" font-size="13" font-weight="600" fill="#0F172A">to society of one more unit.</text><text x="620" y="256" font-size="13" font-weight="700" fill="#059669">MPC</text><text x="620" y="276" font-size="13" font-weight="600" fill="#0F172A">Marginal private cost – what</text><text x="620" y="296" font-size="13" font-weight="600" fill="#0F172A">the firm itself pays.</text><text x="620" y="325" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">BUT THIS IGNORES…</text><text x="620" y="356" font-size="13" font-weight="600" fill="#0F172A">External costs on third parties</text><text x="620" y="376" font-size="13" font-weight="600" fill="#0F172A">(pollution, congestion).</text></g></g><g class="layer-legend-extension"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">MSC = MPC + MEC</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">MSC adds the cost imposed on</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">third parties to private cost.</text><text x="620" y="136" font-size="13" font-weight="700" fill="#0F172A">Vertical gap = MEC</text><text x="620" y="156" font-size="13" font-weight="600" fill="#0F172A">(marginal external cost)</text><text x="620" y="185" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">EXAMPLES OF MEC</text><text x="620" y="216" font-size="13" font-weight="600" fill="#0F172A">Air pollution from a factory</text><text x="620" y="236" font-size="13" font-weight="600" fill="#0F172A">Noise from late-night venues</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">Congestion from extra cars</text><text x="620" y="276" font-size="13" font-weight="600" fill="#0F172A">CO₂ emissions from cement</text><text x="620" y="305" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">THE PROBLEM</text><text x="620" y="336" font-size="13" font-weight="600" fill="#0F172A">Producers don't pay MEC, so</text><text x="620" y="356" font-size="13" font-weight="600" fill="#0F172A">they produce too much.</text></g></g><g class="layer-legend-shift"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">THE OPTIMUM</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">Society maximises welfare</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">where MSC = MSB at</text><text x="620" y="136" font-size="13" font-weight="700" fill="#059669">(Q*, P*).</text><text x="620" y="165" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">COMPARISON</text><text x="620" y="196" font-size="13" font-weight="700" fill="#0F172A">Q* < Q_m</text><text x="620" y="216" font-size="13" font-weight="600" fill="#0F172A">Society wants less output.</text><text x="620" y="236" font-size="13" font-weight="700" fill="#0F172A">P* > P_m</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">Optimal price is higher.</text><text x="620" y="285" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">FREE MARKET FAILS</text><text x="620" y="316" font-size="13" font-weight="600" fill="#0F172A">Without intervention the market</text><text x="620" y="336" font-size="13" font-weight="600" fill="#0F172A">overproduces by (Q_m − Q*).</text></g></g><g class="layer-legend-efficiency"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">DEADWEIGHT WELFARE LOSS</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">Shaded triangle between Q*</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">and Q_m, bounded above by</text><text x="620" y="136" font-size="13" font-weight="600" fill="#0F172A">MSC and below by MSB.</text><text x="620" y="156" font-size="13" font-weight="700" fill="#0F172A">For each over-produced unit:</text><text x="620" y="176" font-size="13" font-weight="600" fill="#0F172A">MSC > MSB → society loses</text><text x="620" y="196" font-size="13" font-weight="600" fill="#0F172A">(MSC − MSB) of welfare.</text><text x="620" y="225" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">POLICY RESPONSE</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">A Pigouvian tax = MEC at Q*</text><text x="620" y="276" font-size="13" font-weight="600" fill="#0F172A">internalises the externality</text><text x="620" y="296" font-size="13" font-weight="600" fill="#0F172A">and eliminates the DWL.</text><text x="620" y="325" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">EXAM TECHNIQUE</text><text x="620" y="356" font-size="13" font-weight="600" fill="#0F172A">Label all six: D=MSB, MPC,</text><text x="620" y="376" font-size="13" font-weight="600" fill="#0F172A">MSC, E_m, E*, DWL.</text></g></g></svg>"`;

exports[`chart SVG regression > pos-externality-interactive.js renders unchanged SVG markup > ECONOS_POS_EXTERNALITY_SPEC 1`] = `"<svg class="posext-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D = MPB, MPC = MSC, MSB curves and E_market, E* points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D = MPB, MPC = MSC, MSB. Points: E_market at (0.37, 0.37), E* at (0.49, 0.49).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="595" y1="16" x2="595" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-wfg"><polygon points="244,266.839 303,223.999 244,196.86700000000002" fill="#DCFCE7" opacity="0.85"/></g><g class="layer-base-curves"><path d="M 100.0,200.1L 490.0,380.0" fill="none" stroke="#D97706" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="498" y="384.008" font-size="13" font-weight="700" fill="#D97706">D = MPB</text></g><g class="layer-base-curves"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="498" y="86.12400000000002" font-size="13" font-weight="700" fill="#059669">MPC = MSC</text></g><g class="layer-msb"><path d="M 100.0,130.1L 490.0,310.0" fill="none" stroke="#2563EB" stroke-width="3" stroke-dasharray="9 5" clip-path="url(#econos-chart-clip)"/><text x="498" y="314.036" font-size="13" font-weight="700" fill="#2563EB">MSB</text></g><g class="layer-market-eq"><path d="M 60,266.839 L 244,266.839" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><path d="M 244,266.839 L 244,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-meb"><path d="M 380,328.957 L 380,258.985" fill="none" stroke="#7C3AED" stroke-width="3"/></g><g class="layer-optimal"><path d="M 60,223.999 L 303,223.999" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-optimal"><path d="M 303,223.999 L 303,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><g class="chart-point"><circle cx="244" cy="266.839" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/><text x="256" y="262.839" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">E_market</text></g></g><g class="layer-optimal"><g class="chart-point"><circle cx="303" cy="223.999" r="7" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="303" y="207.999" font-size="13" font-weight="700" fill="#059669" text-anchor="middle" dominant-baseline="middle">E*</text></g></g><g class="layer-legend-base"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#DC2626"/></g></g><g class="layer-legend-extension"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#7C3AED"/></g></g><g class="layer-legend-shift"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#059669"/></g></g><g class="layer-legend-efficiency"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#059669"/></g></g><g class="layer-market-eq"><text x="46" y="266.839" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P_m</text></g><g class="layer-market-eq"><text x="244" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q_m</text></g><g class="layer-meb"><text x="392" y="293.971" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">MEB</text></g><g class="layer-optimal"><text x="46" y="223.999" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P*</text></g><g class="layer-optimal"><text x="303" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-wfg"><text x="273.6666666666667" y="224.951" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Welfare</text></g><g class="layer-wfg"><text x="273.6666666666667" y="238.16" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">gain</text></g><g class="layer-legend-base"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Free market equilibrium: MPC = MPB</text></g><g class="layer-legend-extension"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Consumption creates external benefits → MSB sits above MPB</text></g><g class="layer-legend-shift"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Socially optimal output: where MSB = MSC</text></g><g class="layer-legend-efficiency"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Under-consumption → welfare gain triangle forgone</text></g><g class="layer-legend-base"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">FREE MARKET OUTCOME</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">Consumers maximise utility at</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">MPC = MPB → equilibrium at</text><text x="620" y="136" font-size="13" font-weight="700" fill="#0F172A">(Q_m, P_m).</text><text x="620" y="165" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">WHAT EACH CURVE MEANS</text><text x="620" y="196" font-size="13" font-weight="700" fill="#D97706">D = MPB</text><text x="620" y="216" font-size="13" font-weight="600" fill="#0F172A">Marginal private benefit – value to</text><text x="620" y="236" font-size="13" font-weight="600" fill="#0F172A">the consumer of one more unit.</text><text x="620" y="256" font-size="13" font-weight="700" fill="#059669">MPC = MSC</text><text x="620" y="276" font-size="13" font-weight="600" fill="#0F172A">Same private and social cost</text><text x="620" y="296" font-size="13" font-weight="600" fill="#0F172A">(no production externality).</text><text x="620" y="325" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">BUT THIS IGNORES…</text><text x="620" y="356" font-size="13" font-weight="600" fill="#0F172A">External benefits to third parties</text><text x="620" y="376" font-size="13" font-weight="600" fill="#0F172A">(herd immunity, productivity).</text></g></g><g class="layer-legend-extension"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">MSB = MPB + MEB</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">MSB adds the benefit enjoyed by</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">third parties to private benefit.</text><text x="620" y="136" font-size="13" font-weight="700" fill="#0F172A">Vertical gap = MEB</text><text x="620" y="156" font-size="13" font-weight="600" fill="#0F172A">(marginal external benefit)</text><text x="620" y="185" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">EXAMPLES OF MEB</text><text x="620" y="216" font-size="13" font-weight="600" fill="#0F172A">Herd immunity from vaccination</text><text x="620" y="236" font-size="13" font-weight="600" fill="#0F172A">Productivity from education</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">Lower crime from schooling</text><text x="620" y="276" font-size="13" font-weight="600" fill="#0F172A">Pollination from beekeeping</text><text x="620" y="305" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">THE PROBLEM</text><text x="620" y="336" font-size="13" font-weight="600" fill="#0F172A">Consumers don't capture MEB,</text><text x="620" y="356" font-size="13" font-weight="600" fill="#0F172A">so they consume too little.</text></g></g><g class="layer-legend-shift"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">THE OPTIMUM</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">Society maximises welfare</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">where MSB = MSC at</text><text x="620" y="136" font-size="13" font-weight="700" fill="#059669">(Q*, P*).</text><text x="620" y="165" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">COMPARISON</text><text x="620" y="196" font-size="13" font-weight="700" fill="#0F172A">Q* > Q_m</text><text x="620" y="216" font-size="13" font-weight="600" fill="#0F172A">Society wants more output.</text><text x="620" y="236" font-size="13" font-weight="700" fill="#0F172A">P* > P_m</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">Optimal price is higher.</text><text x="620" y="285" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">FREE MARKET FAILS</text><text x="620" y="316" font-size="13" font-weight="600" fill="#0F172A">Without intervention the market</text><text x="620" y="336" font-size="13" font-weight="600" fill="#0F172A">under-produces by (Q* − Q_m).</text></g></g><g class="layer-legend-efficiency"><g class="chart-legend"><text x="620" y="65" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">WELFARE GAIN FORGONE</text><text x="620" y="96" font-size="13" font-weight="600" fill="#0F172A">Shaded triangle between Q_m</text><text x="620" y="116" font-size="13" font-weight="600" fill="#0F172A">and Q*, bounded above by</text><text x="620" y="136" font-size="13" font-weight="600" fill="#0F172A">MSB and below by MSC.</text><text x="620" y="156" font-size="13" font-weight="700" fill="#0F172A">For each unit Q_m → Q*:</text><text x="620" y="176" font-size="13" font-weight="600" fill="#0F172A">MSB > MSC → society gains</text><text x="620" y="196" font-size="13" font-weight="600" fill="#0F172A">(MSB − MSC) of welfare.</text><text x="620" y="225" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">POLICY RESPONSE</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">A Pigouvian subsidy = MEB at Q*</text><text x="620" y="276" font-size="13" font-weight="600" fill="#0F172A">internalises the externality</text><text x="620" y="296" font-size="13" font-weight="600" fill="#0F172A">and closes the wedge.</text><text x="620" y="325" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">EXAM TECHNIQUE</text><text x="620" y="356" font-size="13" font-weight="600" fill="#0F172A">Label all six: D=MPB, MPC=MSC,</text><text x="620" y="376" font-size="13" font-weight="600" fill="#0F172A">MSB, E_m, E*, welfare gain.</text></g></g></svg>"`;

exports[`chart SVG regression > ppf-card1.js renders unchanged SVG markup > ECONOS_PPF_CARD1_SPEC 1`] = `"<svg class="ppf-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂, PPF₃ curves and A, B, C, D, E, F, G, H points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂, PPF₃. Points: A at (0.46, 0.41), B at (0.24, 0.26), C at (0.67, 0.57), D at (0.25, 0.57), E at (0.60, 0.20), F at (0.46, 0.41), G at (0.34, 0.52), H at (0.23, 0.26).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="50" width="500" height="350"/></clipPath><marker id="ppf-occ-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#D97706"/></marker><marker id="ppf-shift-out-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#059669"/></marker><marker id="ppf-shift-out-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#059669"/></marker><marker id="ppf-shift-in-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#DC2626"/></marker><marker id="ppf-shift-in-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#DC2626"/></marker></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="595" y1="16" x2="595" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="45" stroke="#334155" stroke-width="2"/><polygon points="60,40 56,52 64,52" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="35" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="layer-ppf-base"><path d="M 60.0,174.9C 240.0,174.9,385.0,319.9,385.0,395.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="391" y="389.1" font-size="13" font-weight="700" fill="#2563EB">PPF₁</text></g><g class="layer-base-points"><line x1="60" y1="256.85" x2="290" y2="256.85" stroke="#94A3B8" stroke-width="1" stroke-dasharray="4 3"/><line x1="290" y1="400" x2="290" y2="256.85" stroke="#94A3B8" stroke-width="1" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="290" cy="256.85" r="7" fill="#2563EB"/><text x="301" y="271.85" font-size="13" font-weight="700" fill="#2563EB" text-anchor="start" dominant-baseline="middle">A</text><text x="315" y="271.85" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Efficient (on PPF)</text></g><g class="chart-point"><circle cx="180" cy="310.05" r="7" fill="#D97706"/><text x="190" y="310.05" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">B</text><text x="204" y="310.05" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Inefficient (inside)</text></g><g class="chart-point"><circle cx="395" cy="200.15" r="7" fill="#DC2626"/><text x="405" y="200.15" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">C</text><text x="419" y="200.15" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Unattainable</text></g><text x="100" y="369.9" font-size="12" font-weight="600" fill="#D97706" font-style="italic" text-anchor="start">Inefficient zone</text><text x="430" y="155.00000000000003" font-size="12" font-weight="600" fill="#DC2626" font-style="italic" text-anchor="end">Unattainable zone</text></g><g class="layer-legend-base"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#2563EB"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Frontier = maximum output · three zones</text><text x="620" y="75" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">THREE ZONES</text><circle cx="627" cy="101" r="7" fill="#2563EB"/><text x="642" y="106" font-size="13" font-weight="600" fill="#0F172A">On the PPF · Productively efficient</text><circle cx="627" cy="131" r="7" fill="#D97706"/><text x="642" y="136" font-size="13" font-weight="600" fill="#0F172A">Inside · Inefficient, wasted resources</text><circle cx="627" cy="161" r="7" fill="#DC2626"/><text x="642" y="166" font-size="13" font-weight="600" fill="#0F172A">Outside · Unattainable now</text><text x="620" y="205" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">WHY IT SLOPES DOWN</text><text x="620" y="236" font-size="13" font-weight="600" fill="#0F172A">More of one good always means</text><text x="620" y="256" font-size="13" font-weight="600" fill="#0F172A">less of the other – scarcity.</text></g></g><g class="layer-opp-cost"><path d="M 210.4,198.0 Q 310.0,169.0 348.4,312.6" fill="none" stroke="#D97706" stroke-width="2" stroke-dasharray="6 3" marker-end="url(#ppf-occ-end)"/><line x1="60" y1="199.10000000000002" x2="187" y2="199.10000000000002" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="187" y1="400" x2="187" y2="199.10000000000002" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="203.10000000000002" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">C₁</text><text x="187" y="417" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">K₁</text><g class="chart-point"><circle cx="187" cy="199.10000000000002" r="7" fill="#D97706"/><text x="197" y="190.10000000000002" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">D</text></g><line x1="60" y1="328.95" x2="360" y2="328.95" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="360" y1="400" x2="360" y2="328.95" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="332.95" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">C₂</text><text x="360" y="417" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">K₂</text><g class="chart-point"><circle cx="360" cy="328.95" r="7" fill="#D97706"/><text x="370" y="319.95" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">E</text></g><text x="45" y="263.85" font-size="12" fill="#D97706" text-anchor="end" font-weight="700">−ΔC</text><text x="273.5" y="417.5" font-size="12" fill="#D97706" text-anchor="middle" font-weight="700">+ΔK</text></g><g class="layer-legend-extension"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#D97706"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Movement along PPF = opportunity cost</text><text x="620" y="75" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">OPPORTUNITY COST</text><text x="620" y="106" font-size="13" font-weight="600" fill="#0F172A">Moving D → E:</text><text x="620" y="126" font-size="13" font-weight="700" fill="#059669">+ more capital goods</text><text x="620" y="146" font-size="13" font-weight="700" fill="#DC2626">− fewer consumer goods</text><text x="620" y="175" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">WHY BOWED OUT</text><text x="620" y="206" font-size="13" font-weight="600" fill="#0F172A">Resource adaptability falls as the</text><text x="620" y="226" font-size="13" font-weight="600" fill="#0F172A">economy specialises. To gain more</text><text x="620" y="246" font-size="13" font-weight="600" fill="#0F172A">capital goods, you must give up</text><text x="620" y="266" font-size="13" font-weight="600" fill="#0F172A">progressively more consumer goods.</text><text x="620" y="286" font-size="12" font-weight="600" fill="#0F172A" font-style="italic">= Increasing opportunity cost</text></g></g><g class="layer-shift-curves"><path d="M 60.0,174.9C 240.0,174.9,385.0,319.9,385.0,395.1" fill="none" stroke="#2563EB" stroke-width="2" stroke-dasharray="9 5" opacity="0.55" clip-path="url(#econos-chart-clip)"/><path d="M 60.0,115.1C 280.0,115.1,460.0,310.1,460.0,395.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="466" y="389.1" font-size="13" font-weight="700" fill="#2563EB">PPF₂</text><path d="M 60.0,240.0C 175.0,240.0,300.0,349.9,300.0,395.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="306" y="389.1" font-size="13" font-weight="700" fill="#2563EB">PPF₃</text><path d="M 319.1,263.9 L 349.7,246.8" fill="none" stroke="#059669" stroke-width="3" stroke-linecap="round" marker-start="url(#ppf-shift-out-start)" marker-end="url(#ppf-shift-out-end)"/><path d="M 221.1,228.5 L 185.4,261.6" fill="none" stroke="#DC2626" stroke-width="3" stroke-linecap="round" marker-start="url(#ppf-shift-in-start)" marker-end="url(#ppf-shift-in-end)"/></g><g class="layer-legend-shift"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#059669"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Shift of PPF = change in productive capacity</text><text x="620" y="75" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">PPF SHIFTS</text><line x1="620" y1="101" x2="640" y2="101" stroke="#2563EB" stroke-width="2.5"/><text x="642" y="106" font-size="13" font-weight="700" fill="#2563EB">PPF₂ – outward</text><text x="642" y="126" font-size="12" fill="#0F172A">Better technology / More resources</text><text x="642" y="144" font-size="12" fill="#0F172A">/ Higher productivity</text><line x1="620" y1="161" x2="640" y2="161" stroke="#2563EB" stroke-width="2.5"/><text x="642" y="166" font-size="13" font-weight="700" fill="#2563EB">PPF₃ – inward</text><text x="642" y="186" font-size="12" fill="#0F172A">War / natural disaster</text><text x="642" y="204" font-size="12" fill="#0F172A">/ Capital depreciation</text><text x="620" y="235" font-size="12" font-weight="800" fill="#475569" letter-spacing="1.5">MOVEMENT ALONG PPF₁</text><text x="620" y="266" font-size="13" font-weight="600" fill="#0F172A">Just reallocation – no change</text><text x="620" y="286" font-size="13" font-weight="600" fill="#0F172A">in capacity.</text></g></g><g class="layer-efficiency"><line x1="60" y1="257.20000000000005" x2="290" y2="257.20000000000005" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="290" y1="400" x2="290" y2="257.20000000000005" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="290" cy="257.20000000000005" r="7" fill="#7C3AED"/><text x="301" y="272.20000000000005" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">F</text><text x="315" y="272.20000000000005" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Productive efficiency</text></g><g class="chart-point"><circle cx="231" cy="219.04999999999998" r="7" fill="#0891B2"/><text x="241" y="219.04999999999998" font-size="13" font-weight="700" fill="#0891B2" text-anchor="start" dominant-baseline="middle">G</text><text x="255" y="219.04999999999998" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Allocative efficiency (P=MC)</text></g><g class="chart-point"><circle cx="175" cy="307.95" r="7" fill="#94A3B8"/><text x="164" y="296.95" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end" dominant-baseline="middle">H</text><text x="178" y="296.95" font-size="12" fill="#0F172A" text-anchor="end" dominant-baseline="middle">– Inefficient (inside PPF)</text></g></g><g class="layer-legend-efficiency"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#7C3AED"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Productive ≠ allocative efficiency</text><text x="620" y="75" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">EFFICIENCY</text><circle cx="627" cy="101" r="7" fill="#7C3AED"/><text x="642" y="106" font-size="13" font-weight="600" fill="#0F172A">F – Productive efficiency</text><text x="642" y="126" font-size="12" fill="#0F172A">ANY point on the PPF – no waste</text><circle cx="627" cy="143" r="7" fill="#0891B2"/><text x="642" y="148" font-size="13" font-weight="600" fill="#0F172A">G – Allocative efficiency</text><text x="642" y="168" font-size="12" fill="#0F172A">The ONE point society wants most</text><text x="642" y="186" font-size="12" fill="#0F172A">(price = marginal cost)</text><circle cx="627" cy="203" r="7" fill="#94A3B8"/><text x="642" y="208" font-size="13" font-weight="600" fill="#0F172A">H – Inefficient</text><text x="642" y="228" font-size="12" fill="#0F172A">Inside PPF – resources idle</text><text x="620" y="259" font-size="12" font-weight="800" fill="#0891B2" letter-spacing="1.5">KEY INSIGHT</text><text x="620" y="290" font-size="13" font-weight="600" fill="#0F172A">Many points are productively</text><text x="620" y="310" font-size="13" font-weight="600" fill="#0F172A">efficient. Only ONE is also</text><text x="620" y="330" font-size="13" font-weight="700" fill="#0891B2">allocatively efficient – G.</text></g></g></svg>"`;

exports[`chart SVG regression > ppf-card2.js renders unchanged SVG markup > ECONOS_PPF_CARD2_SPEC 1`] = `"<svg class="econos-chart" viewBox="0 0 440 300" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF curves</title><desc id="econos-chart-desc">Good B on x-axis, Good A on y-axis. Curves: PPF.</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="30" width="340" height="238"/></clipPath><marker id="ppfboi-ax"  markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#475569"/></marker><marker id="ppfboi-sac" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#DC2626"/></marker><marker id="ppfboi-gn"  markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#059669"/></marker></defs><rect width="440" height="300" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="55" y1="268" x2="55" y2="25" stroke="#334155" stroke-width="2"/><polygon points="55,20 51,32 59,32" fill="#334155"/><line x1="55" y1="268" x2="400" y2="268" stroke="#334155" stroke-width="2"/><polygon points="405,268 393,264 393,272" fill="#334155"/><text x="45" y="282" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="55" y="15" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Good A</text><text x="405" y="286" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Good B</text></g></g><path d="M 55.0,84.3C 242.0,84.3,395.0,256.1,395.0,268.0" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="401" y="262" font-size="13" font-weight="700" fill="#2563EB">PPF</text><g class="idl-1" style="display:none"><line x1="162.16800000000006" y1="102.23014399999994" x2="192.7680000001811" y2="113.65357575713986" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="162.16800000000006" cy="102.23014399999994" r="4.5" fill="#2563EB"/><path d="M 168.2,102.2 L 190.8,102.2" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 192.8,104.2 L 192.8,111.7" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="108.16800000000006" y="78.23014399999994" width="48" height="18" rx="4" fill="#2563EB22"/><text x="132.16800000000006" y="91.23014399999994" font-size="12" font-weight="700" fill="#2563EB" text-anchor="middle">Low OC</text></g><g class="idl-2" style="display:none"><line x1="275.95112500000005" y1="158.42164649999998" x2="306.55112500010694" y2="180.12354541036046" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="275.95112500000005" cy="158.42164649999998" r="4.5" fill="#D97706"/><path d="M 282.0,158.4 L 304.6,158.4" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 306.6,160.4 L 306.6,178.1" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="206.95112500000005" y="134.42164649999998" width="63" height="18" rx="4" fill="#D9770622"/><text x="238.45112500000005" y="147.42164649999998" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">Rising OC</text></g><g class="idl-3" style="display:none"><line x1="356.9029999999999" y1="223.065124" x2="387.50300000003386" y2="255.977445501733" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="356.9029999999999" cy="223.065124" r="4.5" fill="#DC2626"/><path d="M 362.9,223.1 L 385.5,223.1" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 387.5,225.1 L 387.5,254.0" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="301.9029999999999" y="199.065124" width="49" height="18" rx="4" fill="#DC262622"/><text x="326.4029999999999" y="212.065124" font-size="12" font-weight="700" fill="#DC2626" text-anchor="middle">High OC</text></g></svg>"`;

exports[`chart SVG regression > ppf-card3.js renders unchanged SVG markup > ECONOS_PPF_CARD3_SPEC 1`] = `"<svg class="ppf-moves-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂, PPF₃ curves and D, E, X points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂, PPF₃. Points: D at (0.30, 0.55), E at (0.58, 0.25), X at (0.26, 0.23).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="50" width="500" height="350"/></clipPath><marker id="ppfmv-along-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#7C3AED"/></marker><marker id="ppfmv-rec-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#D97706"/></marker><marker id="ppfmv-out-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#059669"/></marker><marker id="ppfmv-out-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#059669"/></marker><marker id="ppfmv-in-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#DC2626"/></marker><marker id="ppfmv-in-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#DC2626"/></marker></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="595" y1="16" x2="595" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="45" stroke="#334155" stroke-width="2"/><polygon points="60,40 56,52 64,52" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="35" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="layer-ppf1"><path d="M 60.0,174.9C 240.0,174.9,385.0,319.9,385.0,395.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="391" y="389.1" font-size="13" font-weight="700" fill="#2563EB">PPF₁</text></g><g class="layer-ppf2"><path d="M 60.0,115.1C 280.0,115.1,460.0,310.1,460.0,395.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="466" y="389.1" font-size="13" font-weight="700" fill="#059669">PPF₂</text></g><g class="layer-ppf3"><path d="M 60.0,240.0C 175.0,240.0,300.0,349.9,300.0,395.1" fill="none" stroke="#DC2626" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="306" y="389.1" font-size="13" font-weight="700" fill="#DC2626">PPF₃</text></g><g class="layer-along"><path d="M 224.0,207.7 Q 285.0,207.5 341.8,301.9" fill="none" stroke="#7C3AED" stroke-width="2" stroke-dasharray="6 3" marker-end="url(#ppfmv-along-end)"/><line x1="60" y1="207.85" x2="210" y2="207.85" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="210" y1="400" x2="210" y2="207.85" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="211.85" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">C₁</text><text x="210" y="417" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">K₁</text><g class="chart-point"><circle cx="210" cy="207.85" r="7" fill="#7C3AED"/><text x="220" y="198.85" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">D</text></g><line x1="60" y1="313.9" x2="349" y2="313.9" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="349" y1="400" x2="349" y2="313.9" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="317.9" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">C₂</text><text x="349" y="417" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">K₂</text><g class="chart-point"><circle cx="349" cy="313.9" r="7" fill="#7C3AED"/><text x="359" y="304.9" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">E</text></g><text x="45" y="260.7" font-size="12" fill="#7D23CB" text-anchor="end" font-weight="700">−ΔC</text><text x="279.5" y="417.5" font-size="12" fill="#7D23CB" text-anchor="middle" font-weight="700">+ΔK</text></g><g class="layer-legend-along"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#7C3AED"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Moving along the PPF: reallocation</text><text x="620" y="75" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">WHAT HAPPENS</text><text x="620" y="106" font-size="13" font-weight="600" fill="#0F172A">D → E: produce more</text><text x="620" y="126" font-size="13" font-weight="700" fill="#059669">+ capital goods (K)</text><text x="620" y="146" font-size="13" font-weight="700" fill="#DC2626">− consumer goods (C)</text><text x="620" y="175" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">KEY POINT</text><text x="620" y="206" font-size="13" font-weight="600" fill="#0F172A">The frontier does NOT move.</text><text x="620" y="226" font-size="13" font-weight="600" fill="#0F172A">Existing resources are just</text><text x="620" y="246" font-size="13" font-weight="600" fill="#0F172A">reallocated between uses.</text><text x="620" y="275" font-size="12" font-weight="800" fill="#7C3AED" letter-spacing="1.5">OPPORTUNITY COST</text><text x="620" y="306" font-size="13" font-weight="600" fill="#0F172A">Every step along the curve</text><text x="620" y="326" font-size="13" font-weight="600" fill="#0F172A">has an opportunity cost –</text><text x="620" y="346" font-size="13" font-weight="600" fill="#0F172A">the slope of the PPF at that point.</text></g></g><g class="layer-recovery"><path d="M 216.7,302.4 L 266.3,269.8" fill="none" stroke="#D97706" stroke-width="2.5" stroke-dasharray="7 4" marker-end="url(#ppfmv-rec-end)"/><g class="chart-point"><circle cx="190" cy="318.1" r="7" fill="#D97706"/><text x="200" y="318.1" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">X</text><text x="214" y="318.1" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Underemployment</text></g><text x="120" y="372" font-size="12" font-weight="600" fill="#D97706" font-style="italic" text-anchor="start">Inefficient zone</text></g><g class="layer-legend-recovery"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#D97706"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Short-run recovery: X moves to PPF₁</text><text x="620" y="75" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">WHAT X REPRESENTS</text><text x="620" y="106" font-size="13" font-weight="600" fill="#0F172A">Inside the frontier:</text><text x="620" y="126" font-size="13" font-weight="600" fill="#0F172A">unemployment, idle capacity,</text><text x="620" y="146" font-size="13" font-weight="600" fill="#0F172A">resources not fully used.</text><text x="620" y="175" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">THE RECOVERY</text><text x="620" y="206" font-size="13" font-weight="600" fill="#0F172A">Demand rises → firms rehire,</text><text x="620" y="226" font-size="13" font-weight="600" fill="#0F172A">spare capacity reactivated.</text><text x="620" y="246" font-size="13" font-weight="700" fill="#059669">X moves onto PPF₁.</text><text x="620" y="275" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">KEY POINT</text><text x="620" y="306" font-size="13" font-weight="600" fill="#0F172A">PPF₁ itself does NOT shift.</text><text x="620" y="326" font-size="13" font-weight="600" fill="#0F172A">This is demand-side / SR growth.</text><text x="620" y="346" font-size="13" font-weight="600" fill="#0F172A">The capacity ceiling is unchanged.</text></g></g><g class="layer-outward"><path d="M 301.8,249.3 L 331.0,230.9" fill="none" stroke="#059669" stroke-width="3" stroke-linecap="round" marker-start="url(#ppfmv-out-start)" marker-end="url(#ppfmv-out-end)"/></g><g class="layer-legend-outward"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#059669"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Outward shift: long-run growth</text><text x="620" y="75" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">CAUSES OF OUTWARD SHIFT</text><text x="620" y="106" font-size="13" font-weight="600" fill="#0F172A">⊕  Better technology</text><text x="620" y="126" font-size="13" font-weight="600" fill="#0F172A">⊕  More capital investment</text><text x="620" y="146" font-size="13" font-weight="600" fill="#0F172A">⊕  Population / labour growth</text><text x="620" y="166" font-size="13" font-weight="600" fill="#0F172A">⊕  Education and training</text><text x="620" y="186" font-size="13" font-weight="600" fill="#0F172A">⊕  Improved infrastructure</text><text x="620" y="215" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">KEY POINT</text><text x="620" y="246" font-size="13" font-weight="600" fill="#0F172A">This is supply-side growth.</text><text x="620" y="266" font-size="13" font-weight="600" fill="#0F172A">Productive capacity permanently</text><text x="620" y="286" font-size="13" font-weight="700" fill="#059669">increases.</text><text x="620" y="315" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">RESULT</text><text x="620" y="346" font-size="12" font-weight="600" fill="#0F172A" font-style="italic">Previously unattainable combinations</text><text x="620" y="366" font-size="12" font-weight="600" fill="#0F172A" font-style="italic">become achievable on PPF₂.</text></g></g><g class="layer-inward"><path d="M 249.0,244.3 L 208.7,275.2" fill="none" stroke="#DC2626" stroke-width="3" stroke-linecap="round" marker-start="url(#ppfmv-in-start)" marker-end="url(#ppfmv-in-end)"/></g><g class="layer-legend-inward"><g class="chart-legend"><circle cx="612" cy="31" r="6" fill="#DC2626"/><text x="626" y="36" font-size="13" font-weight="700" fill="#0F172A">Inward shift: supply shock</text><text x="620" y="75" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">CAUSES OF INWARD SHIFT</text><text x="620" y="106" font-size="13" font-weight="600" fill="#0F172A">⊖  War / conflict (destroys capital)</text><text x="620" y="126" font-size="13" font-weight="600" fill="#0F172A">⊖  Natural disasters</text><text x="620" y="146" font-size="13" font-weight="600" fill="#0F172A">⊖  "Brain drain" emigration</text><text x="620" y="166" font-size="13" font-weight="600" fill="#0F172A">⊖  Capital depreciation</text><text x="620" y="186" font-size="13" font-weight="600" fill="#0F172A">⊖  Disease / population decline</text><text x="620" y="215" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">KEY POINT</text><text x="620" y="246" font-size="13" font-weight="600" fill="#0F172A">Productive capacity falls.</text><text x="620" y="266" font-size="13" font-weight="600" fill="#0F172A">Previously attainable combinations</text><text x="620" y="286" font-size="13" font-weight="700" fill="#DC2626">become unachievable.</text><text x="620" y="315" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">WHERE IT BITES</text><text x="620" y="346" font-size="12" font-weight="600" fill="#0F172A" font-style="italic">Most acute after sudden shocks:</text><text x="620" y="366" font-size="12" font-weight="600" fill="#0F172A" font-style="italic">war, pandemic, major disaster.</text></g></g></svg>"`;

exports[`chart SVG regression > ppf-card4.js renders unchanged SVG markup > ECONOS_PPF_CARD4_SPEC 1`] = `"<svg class="ppf-investment-svg" viewBox="0 0 440 300" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂ curves and Germany, China, B, C, D points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂. Points: Germany at (0.52, 0.35), China at (0.70, 0.11), B at (0.60, 0.25), C at (0.60, 0.55), D at (0.32, 0.77).</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="30" width="340" height="238"/></clipPath><marker id="ppfcc-pp" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#7C3AED"/></marker><marker id="ppfcc-gr" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#059669"/></marker></defs><rect width="440" height="300" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="55" y1="268" x2="55" y2="25" stroke="#334155" stroke-width="2"/><polygon points="55,20 51,32 59,32" fill="#334155"/><line x1="55" y1="268" x2="400" y2="268" stroke="#334155" stroke-width="2"/><polygon points="405,268 393,264 393,272" fill="#334155"/><text x="45" y="282" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="55" y="15" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="405" y="286" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="chart-point"><circle cx="114.5" cy="122.106" r="6" fill="#7C3AED"/></g><g class="countries" style="display:none"><g class="chart-point"><circle cx="231.8" cy="183.986" r="6" fill="#2563EB"/><text x="240.8" y="183.986" font-size="13" font-weight="700" fill="#2563EB" text-anchor="start" dominant-baseline="middle">Ger