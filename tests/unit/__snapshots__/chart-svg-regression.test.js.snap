iddle">O</text><text x="60" y="29" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="420" y="338" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="layer-ppf-base"><path d="M 60.0,142.5C 186.0,142.5,287.5,256.8,287.5,316.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="281.5" y="312.52500000000003" text-anchor="end" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">PPF₁</text></g><g class="layer-base-points"><line x1="60" y1="207.116" x2="221" y2="207.116" stroke="#94A3B8" stroke-width="1" stroke-dasharray="4 3"/><line x1="221" y1="320" x2="221" y2="207.116" stroke="#94A3B8" stroke-width="1" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="221" cy="207.116" r="7" fill="#2563EB"/><text x="232" y="222.116" font-size="13" font-weight="700" fill="#2563EB" text-anchor="start" dominant-baseline="middle">A</text></g><g class="chart-point"><circle cx="144" cy="249.06799999999998" r="7" fill="#D97706"/><text x="154" y="249.06799999999998" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">B</text></g><g class="chart-point"><circle cx="294.5" cy="162.40400000000002" r="7" fill="#DC2626"/><text x="304.5" y="162.40400000000002" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">C</text></g><text x="88" y="296.264" font-size="12" font-weight="600" fill="#D97706" font-style="italic" text-anchor="start">Inefficient zone</text><text x="319" y="126.80000000000001" font-size="12" font-weight="600" fill="#DC2626" font-style="italic" text-anchor="end">Unattainable zone</text></g><g class="layer-opp-cost"><path d="M 169.2,159.4 Q 235.0,137.8 261.2,248.2" fill="none" stroke="#D97706" stroke-width="1.6" stroke-dasharray="6 3" marker-end="url(#ppf-occ-end)"/><line x1="60" y1="161.57600000000002" x2="148.9" y2="161.57600000000002" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="148.9" y1="320" x2="148.9" y2="161.57600000000002" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="165.57600000000002" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">C₁</text><text x="148.9" y="337" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">K₁</text><g class="chart-point"><circle cx="148.9" cy="161.57600000000002" r="7" fill="#D97706"/><text x="158.9" y="152.57600000000002" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">D</text></g><line x1="60" y1="263.972" x2="270" y2="263.972" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="270" y1="320" x2="270" y2="263.972" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="267.972" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">C₂</text><text x="270" y="337" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">K₂</text><g class="chart-point"><circle cx="270" cy="263.972" r="7" fill="#D97706"/><text x="280" y="254.97199999999998" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">E</text></g><text x="49.5" y="212.636" font-size="12" fill="#D97706" text-anchor="end" font-weight="700">−ΔC</text><text x="209.45" y="333.8" font-size="12" fill="#D97706" text-anchor="middle" font-weight="700">+ΔK</text></g><g class="layer-shift-curves"><path d="M 60.0,142.5C 186.0,142.5,287.5,256.8,287.5,316.1" fill="none" stroke="#2563EB" stroke-width="2" stroke-dasharray="9 5" opacity="0.55" clip-path="url(#econos-chart-clip)"/><path d="M 60.0,95.3C 214.0,95.3,340.0,249.1,340.0,316.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="334" y="312.52500000000003" text-anchor="end" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">PPF₂</text><path d="M 60.0,193.9C 140.5,193.9,228.0,280.5,228.0,316.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="228" y="129.66100000000003" text-anchor="middle" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">PPF₃</text><path d="M 244.7,210.6 L 259.5,201.2" fill="none" stroke="#059669" stroke-width="1.8" stroke-linecap="round" marker-start="url(#ppf-shift-out-start)" marker-end="url(#ppf-shift-out-end)"/><path d="M 170.3,187.4 L 150.3,208.3" fill="none" stroke="#DC2626" stroke-width="1.8" stroke-linecap="round" marker-start="url(#ppf-shift-in-start)" marker-end="url(#ppf-shift-in-end)"/><text x="277" y="137.84" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Outward</text><text x="165" y="292.4" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Inward</text></g><g class="layer-efficiency"><line x1="60" y1="207.392" x2="221" y2="207.392" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="221" y1="320" x2="221" y2="207.392" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="221" cy="207.392" r="7" fill="#7C3AED"/><text x="232" y="222.392" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">F</text></g><g class="chart-point"><circle cx="179.7" cy="177.308" r="7" fill="#0891B2"/><text x="189.7" y="177.308" font-size="13" font-weight="700" fill="#0891B2" text-anchor="start" dominant-baseline="middle">G</text></g><g class="chart-point"><circle cx="140.5" cy="247.41199999999998" r="7" fill="#94A3B8"/><text x="129.5" y="236.41199999999998" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end" dominant-baseline="middle">H</text></g></g></svg><div class="econos-chart-legends"><div class="layer-legend-base"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#2563EB;">A · on the curve</strong> – efficient, no waste.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#D97706;">B · inside</strong> – resources lie idle.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#DC2626;">C · outside</strong> – not possible with today’s resources.</div></div></div></div><div class="layer-legend-extension"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#D97706;">Moving D → E:</strong> gain capital goods, lose consumer goods.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">That sacrifice is the <strong style="color:#D97706;">opportunity cost</strong>.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The bowed curve means it rises as you specialise.</div></div></div></div><div class="layer-legend-shift"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#059669;">PPF₂ · outward</strong> – more capacity (better tech, more resources).</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#DC2626;">PPF₃ · inward</strong> – lost capacity (war, disaster, depreciation).</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Moving along one curve is reallocation, not growth.</div></div></div></div><div class="layer-legend-efficiency"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Any point on the curve (like <strong style="color:#7C3AED;">F</strong>) is productively efficient.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Only <strong style="color:#0891B2;">G</strong> is allocatively efficient – what society wants most.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#64748B;">H · inside</strong> the curve wastes resources.</div></div></div></div></div></div>"`;

exports[`chart SVG regression > ppf-card2.js renders unchanged SVG markup > ECONOS_PPF_CARD2_SPEC 1`] = `"<svg class="econos-chart" viewBox="0 -16 460 366" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF curves</title><desc id="econos-chart-desc">Capital goods on x-axis, Consumer goods on y-axis. Curves: PPF.</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="40" width="360" height="270"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="460" height="366" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="310" x2="60" y2="35" stroke="#334155" stroke-width="2"/><polygon points="60,30 56,42 64,42" fill="#334155"/><line x1="60" y1="310" x2="425" y2="310" stroke="#334155" stroke-width="2"/><polygon points="430,310 418,306 418,314" fill="#334155"/><text x="50" y="324" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="25" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer goods</text><text x="430" y="328" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital goods</text></g></g><path d="M 60.0,40.0C 258.8,40.0,420.0,160.9,420.0,310.0" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="414" y="302.52500000000003" text-anchor="end" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">PPF</text><g class="idl-1" style="display:none"><line x1="131.991521462016" y1="45.39928258451198" x2="203.99152146189505" y2="62.462206554506935" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="131.991521462016" cy="45.39928258451198" r="4.5" fill="#059669"/><path d="M 138.0,45.4 L 202.0,45.4" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 204.0,47.4 L 204.0,60.5" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="103.99152146201601" y="63.39928258451198" width="56" height="18" rx="4" fill="#05966922"/><text x="131.991521462016" y="76.39928258451198" font-size="12" font-weight="700" fill="#059669" text-anchor="middle">OC ≈ 1/3</text><text x="132" y="320.8" font-size="12" fill="#0F172A" text-anchor="middle">2</text><text x="204" y="320.8" font-size="12" fill="#0F172A" text-anchor="middle">4</text></g><g class="idl-2" style="display:none"><line x1="275.9944021987684" y1="93.97452957595627" x2="347.99440219874316" y2="147.9647042572352" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="275.9944021987684" cy="93.97452957595627" r="4.5" fill="#2563EB"/><path d="M 282.0,94.0 L 346.0,94.0" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 348.0,96.0 L 348.0,146.0" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="251.9944021987684" y="125.47452957595624" width="48" height="18" rx="4" fill="#2563EB22"/><text x="275.9944021987684" y="138.47452957595624" font-size="12" font-weight="700" fill="#2563EB" text-anchor="middle">OC = 1</text><text x="276" y="320.8" font-size="12" fill="#0F172A" text-anchor="middle">6</text><text x="348" y="320.8" font-size="12" fill="#0F172A" text-anchor="middle">8</text></g><g class="idl-3" style="display:none"><line x1="348.0006972178581" y1="147.97098804566355" x2="419.6406972178506" y2="297.82737705848905" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="348.0006972178581" cy="147.97098804566355" r="4.5" fill="#DC2626"/><path d="M 354.0,148.0 L 417.6,148.0" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 419.6,150.0 L 419.6,295.8" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="324.0006972178581" y="206.4709880456635" width="48" height="18" rx="4" fill="#DC262622"/><text x="348.0006972178581" y="219.4709880456635" font-size="12" font-weight="700" fill="#DC2626" text-anchor="middle">OC ≈ 3</text></g></svg>"`;

exports[`chart SVG regression > ppf-card3.js renders unchanged SVG markup > ECONOS_PPF_CARD3_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="ppf-moves-svg" viewBox="0 -16 590 456" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂, PPF₃ curves and D, E, X points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂, PPF₃. Points: D at (0.30, 0.55), E at (0.58, 0.25), X at (0.26, 0.23).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="50" width="500" height="350"/></clipPath><style>.econos-chart-legends .layer-legend-along,.econos-chart-legends .layer-legend-recovery,.econos-chart-legends .layer-legend-outward,.econos-chart-legends .layer-legend-inward{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-along .econos-chart-legends .layer-legend-along{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-recovery .econos-chart-legends .layer-legend-recovery{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-outward .econos-chart-legends .layer-legend-outward{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-inward .econos-chart-legends .layer-legend-inward{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker><marker id="ppfmv-along-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#7C3AED"/></marker><marker id="ppfmv-rec-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#D97706"/></marker><marker id="ppfmv-out-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#059669"/></marker><marker id="ppfmv-out-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#059669"/></marker><marker id="ppfmv-in-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#DC2626"/></marker><marker id="ppfmv-in-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#DC2626"/></marker></defs><rect x="0" y="-16" width="590" height="456" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="45" stroke="#334155" stroke-width="2"/><polygon points="60,40 56,52 64,52" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="35" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="layer-ppf1"><path d="M 60.0,174.9C 240.0,174.9,385.0,319.9,385.0,395.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="385" y="57.475" text-anchor="middle" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">PPF₁</text></g><g class="layer-ppf2"><path d="M 60.0,115.1C 280.0,115.1,460.0,310.1,460.0,395.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="460" y="74.62500000000003" text-anchor="middle" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">PPF₂</text></g><g class="layer-ppf3"><path d="M 60.0,240.0C 175.0,240.0,300.0,349.9,300.0,395.1" fill="none" stroke="#DC2626" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="300" y="162.62500000000003" text-anchor="middle" font-size="13" font-weight="700" fill="#DC2626" dominant-baseline="middle">PPF₃</text></g><g class="layer-along"><path d="M 224.0,207.7 Q 285.0,207.5 341.8,301.9" fill="none" stroke="#7C3AED" stroke-width="2" stroke-dasharray="6 3" marker-end="url(#ppfmv-along-end)"/><line x1="60" y1="207.85" x2="210" y2="207.85" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="210" y1="400" x2="210" y2="207.85" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="211.85" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">C₁</text><text x="210" y="417" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">K₁</text><g class="chart-point"><circle cx="210" cy="207.85" r="7" fill="#7C3AED"/><text x="220" y="198.85" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">D</text></g><line x1="60" y1="313.9" x2="349" y2="313.9" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="349" y1="400" x2="349" y2="313.9" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="317.9" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">C₂</text><text x="349" y="417" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">K₂</text><g class="chart-point"><circle cx="349" cy="313.9" r="7" fill="#7C3AED"/><text x="359" y="304.9" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">E</text></g><text x="45" y="260.7" font-size="12" fill="#7D23CB" text-anchor="end" font-weight="700">−ΔC</text><text x="279.5" y="417.5" font-size="12" fill="#7D23CB" text-anchor="middle" font-weight="700">+ΔK</text></g><g class="layer-recovery"><path d="M 216.7,302.4 L 266.3,269.8" fill="none" stroke="#D97706" stroke-width="2.5" stroke-dasharray="7 4" marker-end="url(#ppfmv-rec-end)"/><g class="chart-point"><circle cx="190" cy="318.1" r="7" fill="#D97706"/><text x="200" y="318.1" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">X</text><text x="214" y="318.1" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Underemployment</text></g><text x="120" y="372" font-size="12" font-weight="600" fill="#D97706" font-style="italic" text-anchor="start">Inefficient zone</text></g><g class="layer-outward"><path d="M 301.8,249.3 L 331.0,230.9" fill="none" stroke="#059669" stroke-width="3" stroke-linecap="round" marker-start="url(#ppfmv-out-start)" marker-end="url(#ppfmv-out-end)"/></g><g class="layer-inward"><path d="M 249.0,244.3 L 208.7,275.2" fill="none" stroke="#DC2626" stroke-width="3" stroke-linecap="round" marker-start="url(#ppfmv-in-start)" marker-end="url(#ppfmv-in-end)"/></g></svg><div class="econos-chart-legends"><div class="layer-legend-along"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#7C3AED;"></span><span>Moving along the PPF: reallocation</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">WHAT HAPPENS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">D → E: produce more</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">+ capital goods (K)</div><div class="econos-chart-legend__body" style="color:#DC2626;font-weight:700;font-size:13px;">− consumer goods (C)</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The frontier does NOT move.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Existing resources are just</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">reallocated between uses.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">OPPORTUNITY COST</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Every step along the curve</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">has an opportunity cost –</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">the slope of the PPF at that point.</div></div></div></div><div class="layer-legend-recovery"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#D97706;"></span><span>Short-run recovery: X moves to PPF₁</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#D97706;">WHAT X REPRESENTS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Inside the frontier:</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">unemployment, idle capacity,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">resources not fully used.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#D97706;">THE RECOVERY</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Demand rises → firms rehire,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">spare capacity reactivated.</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">X moves onto PPF₁.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#D97706;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">PPF₁ itself does NOT shift.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">This is demand-side / SR growth.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The capacity ceiling is unchanged.</div></div></div></div><div class="layer-legend-outward"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#059669;"></span><span>Outward shift: long-run growth</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">CAUSES OF OUTWARD SHIFT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Better technology</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  More capital investment</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Population / labour growth</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Education and training</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Improved infrastructure</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">This is supply-side growth.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Productive capacity permanently</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">increases.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">RESULT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">Previously unattainable combinations</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">become achievable on PPF₂.</div></div></div></div><div class="layer-legend-inward"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#DC2626;"></span><span>Inward shift: supply shock</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">CAUSES OF INWARD SHIFT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  War / conflict (destroys capital)</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  Natural disasters</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  "Brain drain" emigration</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  Capital depreciation</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  Disease / population decline</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Productive capacity falls.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Previously attainable combinations</div><div class="econos-chart-legend__body" style="color:#DC2626;font-weight:700;font-size:13px;">become unachievable.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">WHERE IT BITES</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">Most acute after sudden shocks:</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">war, pandemic, major disaster.</div></div></div></div></div></div>"`;

exports[`chart SVG regression > ppf-card4.js renders unchanged SVG markup > ECONOS_PPF_CARD4_SPEC 1`] = `"<svg class="ppf-investment-svg" viewBox="0 -16 440 316" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂ curves and Germany, China, B, C, D points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂. Points: Germany at (0.52, 0.35), China at (0.70, 0.11), B at (0.60, 0.25), C at (0.60, 0.55), D at (0.32, 0.77).</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="30" width="340" height="238"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker><marker id="ppfcc-pp" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#7C3AED"/></marker><marker id="ppfcc-gr" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#059669"/></marker></defs><rect x="0" y="-16" width="440" height="316" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="55" y1="268" x2="55" y2="25" stroke="#334155" stroke-width="2"/><polygon points="55,20 51,32 59,32" fill="#334155"/><line x1="55" y1="268" x2="400" y2="268" stroke="#334155" stroke-width="2"/><polygon points="405,268 393,264 393,272" fill="#334155"/><text x="45" y="282" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="55" y="15" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="405" y="286" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="chart-point"><circle cx="114.5" cy="122.106" r="6" fill="#7C3AED"/></g><g class="countries" style="display:none"><g class="chart-point"><circle cx="231.8" cy="183.986" r="6" fill="#2563EB"/><text x="240.8" y="183.986" font-size="13" font-weight="700" fill="#2563EB" text-anchor="start" dominant-baseline="middle">Germany</text></g><g class="chart-point"><circle cx="293" cy="242.296" r="6" fill="#D97706"/><text x="302" y="242.296" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">China</text></g><text x="124.7" y="122.106" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">UK</text></g><g class="ppf1s" style="display:none"><path d="M 55.0,113.3C 191.0,113.3,310.0,256.1,310.0,268.0" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="310" y="171.525" text-anchor="middle" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">PPF₁</text></g><g class="ppf1d" style="display:none"><path d="M 55.0,113.3C 191.0,113.3,310.0,256.1,310.0,268.0" fill="none" str