"/><text x="496" y="84.12400000000002" font-size="13" font-weight="700" fill="#DC2626">S₁</text></g><g class="layer-shift"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#DC2626" stroke-width="2" stroke-dasharray="9 5" opacity="0.55" clip-path="url(#econos-chart-clip)"/></g><g class="layer-shift"><path d="M 30.0,370.0L 420.0,90.1" fill="none" stroke="#DC2626" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="428" y="84.12400000000002" font-size="13" font-weight="700" fill="#DC2626">S₀</text></g><g class="layer-shift"><path d="M 170.0,370.0L 560.0,90.1" fill="none" stroke="#DC2626" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="568" y="84.12400000000002" font-size="13" font-weight="700" fill="#DC2626">S₂</text></g><g class="layer-e1"><path d="M 60,230.068 L 295,230.068" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-e1"><path d="M 295,230.068 L 295,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 60,170.09199999999998 L 378,170.09199999999998" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 378,170.09199999999998 L 378,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 60,295.04200000000003 L 204,295.04200000000003" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 204,295.04200000000003 L 204,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-extension"><path d="M 199.5,276.83500000000004 L 360.5,162.595" fill="none" stroke="#D97706" stroke-width="2.5" marker-start="url(#sp-amber-start)" marker-end="url(#sp-amber-end)"/></g><g class="layer-shift"><path d="M 225,246.49 L 225,400" fill="none" stroke="#DC2626" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-shift"><path d="M 365,246.49 L 365,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-shift"><path d="M 300,230.068 L 361,230.068" fill="none" stroke="#059669" stroke-width="3.5" marker-end="url(#sp-green-end)"/></g><g class="layer-shift"><path d="M 290,230.068 L 229,230.068" fill="none" stroke="#DC2626" stroke-width="3.5" marker-end="url(#sp-red-end)"/></g><g class="layer-e1"><g class="chart-point"><circle cx="295" cy="230.068" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-extension"><g class="chart-point"><circle cx="378" cy="170.09199999999998" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-extension"><g class="chart-point"><circle cx="204" cy="295.04200000000003" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="225" cy="230.068" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="295" cy="230.068" r="4" fill="#475569"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="365" cy="230.068" r="6" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="layer-legend-base"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#DC2626"/></g></g><g class="layer-extension"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#D97706"/></g></g><g class="layer-shift"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#059669"/></g></g><g class="layer-legend-base"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Supply slopes upward · higher prices incentivise more production</text></g><g class="layer-extension"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Price changes → slide ALONG the supply curve</text></g><g class="layer-shift"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Non-price factors → SHIFT the whole supply curve</text></g><g class="layer-e1"><text x="46" y="230.068" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P₁</text></g><g class="layer-e1"><text x="295" y="417.85" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q₁</text></g><g class="layer-extension"><text x="46" y="170.09199999999998" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P₂</text></g><g class="layer-extension"><text x="378" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q₂</text></g><g class="layer-extension"><text x="46" y="295.04200000000003" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P₃</text></g><g class="layer-extension"><text x="204" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q₃</text></g><g class="layer-extension"><text x="386" y="157.95399999999998" font-size="12" fill="#059669" text-anchor="start" font-weight="700">extension</text></g><g class="layer-extension"><text x="150" y="315.034" font-size="12" fill="#DC2626" text-anchor="start" font-weight="700">contraction</text></g><g class="layer-shift"><text x="500" y="87.98200000000003" font-size="13" fill="#DC2626" text-anchor="start" font-weight="700" opacity="0.55">S₁</text></g><g class="layer-shift"><text x="225" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q₀</text></g><g class="layer-shift"><text x="295" y="417.85" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q₁</text></g><g class="layer-shift"><text x="365" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q₂</text></g><g class="layer-legend-base"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">THE SUPPLY CURVE</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">Upward sloping: higher prices</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">make production more profitable</text><text x="620" y="143" font-size="13" font-weight="700" fill="#0F172A">→ more is supplied.</text><text x="620" y="172" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">WHY IT SLOPES UP</text><text x="620" y="203" font-size="13" font-weight="700" fill="#0F172A">① Profit motive:</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">higher prices cover rising</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">marginal costs</text><text x="620" y="263" font-size="13" font-weight="700" fill="#0F172A">② New entrants:</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">higher prices attract new firms</text><text x="620" y="303" font-size="13" font-weight="600" fill="#0F172A">into the market</text><text x="620" y="332" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">AT EQUILIBRIUM</text><text x="620" y="363" font-size="13" font-weight="600" fill="#0F172A">Quantity supplied Q₁ at price P₁.</text></g></g><g class="layer-legend-extension"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">MOVEMENT ALONG CURVE</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">Only a price change causes this.</text><text x="620" y="132" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">EXTENSION (E₂)</text><text x="620" y="163" font-size="13" font-weight="600" fill="#0F172A">P rises → Q supplied rises</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">Move up the curve.</text><text x="620" y="212" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">CONTRACTION (E₃)</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">P falls → Q supplied falls</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">Move down the curve.</text><text x="620" y="292" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">EXAM LANGUAGE</text><text x="620" y="323" font-size="13" font-weight="600" fill="#0F172A">Say "quantity supplied rises/falls,"</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">not "supply rises/falls."</text></g></g><g class="layer-legend-shift"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">SHIFT OF SUPPLY</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">A non-price determinant changes –</text><text x="620" y="123" font-size="13" font-weight="600" fill="#0F172A">the whole curve moves.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">S₂ – RIGHT (INCREASE)</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">Lower costs / Better technology /</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">More producers / Subsidies</text><text x="620" y="232" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">S₀ – LEFT (DECREASE)</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">Higher wages / Input price rise /</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">New tax / Supply shock</text><text x="620" y="312" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">REMEMBER</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">At every price, more (S₂) or less</text><text x="620" y="363" font-size="13" font-weight="600" fill="#0F172A">(S₀) is supplied.</text></g></g></svg>"`;

exports[`chart SVG regression > supply-card4.js renders unchanged SVG markup > ECONOS_SUPPLY_CARD4_SPEC 1`] = `"<svg class="supply-ps-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with S curves</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: S.</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="515" height="357"/></clipPath></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="608" y1="16" x2="608" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="580" y2="400" stroke="#334155" stroke-width="2"/><polygon points="585,400 573,396 573,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="585" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-ps"><polygon points="60,375.01 60,235.066 292.78,235.066" fill="#FEE2E2" opacity="0.85"/></g><g class="layer-prise-ps"><polygon points="60,375.01 60,175.09 393.205,175.09" fill="#FEE2E2" opacity="0.85"/></g><g class="layer-supply"><path d="M 60.0,375.0L 560.1,75.1" fill="none" stroke="#DC2626" stroke-width="3.5" clip-path="url(#econos-chart-clip)"/><text x="570.065" y="75.13" font-size="13" font-weight="700" fill="#DC2626">S</text></g><g class="layer-eq"><path d="M 60,235.066 L 292.78,235.066" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-eq"><path d="M 292.78,235.066 L 292.78,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-prise"><path d="M 60,235.066 L 393.205,235.066" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="4 4"/></g><g class="layer-prise"><path d="M 292.78,235.066 L 292.78,400" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="4 4"/></g><g class="layer-prise"><path d="M 60,175.09 L 393.205,175.09" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-prise"><path d="M 393.205,175.09 L 393.205,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-eq"><g class="chart-point"><circle cx="292.78" cy="235.066" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-prise"><g class="chart-point"><circle cx="393.205" cy="175.09" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/></g></g><g class="layer-eq"><text x="44.55" y="235.066" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P*</text></g><g class="layer-eq"><text x="292.78" y="416.065" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-ps-label"><text x="125.92" y="295.04200000000003" font-size="18" fill="#DC2626" text-anchor="middle" font-weight="700">PS</text></g><g class="layer-prise"><text x="44.55" y="235.066" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P*</text></g><g class="layer-prise"><text x="292.78" y="416.065" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-prise"><text x="44.55" y="175.09" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P₂</text></g><g class="layer-prise"><text x="393.205" y="416.065" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q₂</text></g><g class="layer-prise"><text x="150.125" y="295.04200000000003" font-size="18" fill="#DC2626" text-anchor="middle" font-weight="700">PS</text></g><text x="626.5" y="32.289999999999964" font-size="12" fill="#0F172A" text-anchor="start" font-weight="700">TAP A STEP TO BUILD THE DIAGRAM</text><g class="layer-legend-base"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#475569" letter-spacing="1.5">THE SUPPLY CURVE</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">Each point on S shows the</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">minimum a seller would accept.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">MIN ACCEPTABLE PRICE</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">Low-cost producers supply at low</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">prices. Higher-cost sellers need</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">a higher price to enter.</text><text x="620" y="252" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">THE MARKET PRICE</text><text x="620" y="283" font-size="13" font-weight="600" fill="#0F172A">Everyone receives the same price</text><text x="620" y="303" font-size="13" font-weight="600" fill="#0F172A">P* – but low-cost sellers earn a</text><text x="620" y="323" font-size="13" font-weight="600" fill="#0F172A">surplus. Tap to reveal it.</text></g></g><g class="layer-ps-label"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">PRODUCER SURPLUS</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">The rose triangle: sellers got</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">P* but would have accepted less.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">THREE VERTICES</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">① P-axis: where S meets the price</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">   axis (min acceptable price)</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">② (Q*, P*): equilibrium point</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">③ (0, P*): market price on P-axis</text><text x="620" y="272" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">FORMULA</text><text x="620" y="303" font-size="13" font-weight="600" fill="#0F172A">PS = ½ × Q* × (P* − min supply P)</text><text x="620" y="332" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">KEY POINT</text><text x="620" y="363" font-size="13" font-weight="600" fill="#0F172A">PS is maximised at the free-market</text><text x="620" y="383" font-size="13" font-weight="600" fill="#0F172A">equilibrium. Taxes reduce it.</text></g></g><g class="layer-prise"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#DC2626" letter-spacing="1.5">PRICE RISES → PS EXPANDS</text><text x="620" y="103" font-size="13" font-weight="700" fill="#0F172A">When price rises from P* to P₂,</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">producer surplus gets bigger.</text><text x="620" y="152" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">TWO GAINS</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">① Existing sellers earn (P₂−P*) on</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">   every unit already supplied</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">② New sellers enter who weren't</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">   profitable at P* – output extends</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">   to Q₂</text><text x="620" y="292" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">REVERSE: PRICE FALLS</text><text x="620" y="323" font-size="13" font-weight="600" fill="#0F172A">PS shrinks – sellers earn less</text><text x="620" y="343" font-size="13" font-weight="600" fill="#0F172A">and some exit the market.</text><text x="620" y="372" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">EXAM POINT</text><text x="620" y="403" font-size="13" font-weight="600" fill="#0F172A">A tax lowers producer price → PS</text><text x="620" y="423" font-size="13" font-weight="600" fill="#0F172A">falls – part lost, part to govt.</text></g></g></svg>"`;

exports[`chart SVG regression > tax-diagram-interactive.js renders unchanged SVG markup > ECONOS_TAX_DIAGRAM_SPEC 1`] = `"<svg class="tax-diagram-svg" viewBox="0 0 470 420" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D, S curves</title><desc id="econos-chart-desc">Quantity on x-axis, Price on y-axis. Curves: D, S.</desc><defs><clipPath id="econos-chart-clip"><rect x="100" y="26" width="348" height="348"/></clipPath></defs><rect width="470" height="420" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="100" y1="374" x2="100" y2="21" stroke="#334155" stroke-width="2"/><polygon points="100,16 96,28 104,28" fill="#334155"/><line x1="100" y1="374" x2="453" y2="374" stroke="#334155" stroke-width="2"/><polygon points="458,374 446,370 446,378" fill="#334155"/><text x="90" y="388" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="100" y="11" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price</text><text x="458" y="392" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Quantity</text></g></g><path d="M 100.0,39.9L 440.0,360.1" fill="none" stroke="#2563EB" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/><text x="447.996" y="364.08" font-size="13" font-weight="700" fill="#2563EB">D</text><path d="M 100.0,360.1L 440.0,39.9" fill="none" stroke="#D97706" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/><text x="447.996" y="35.920000000000016" font-size="13" font-weight="700" fill="#D97706">S</text><path d="M 100,200 L 270.172,200" fill="none" stroke="#475569" stroke-width="1.4" stroke-dasharray="5 3"/><path d="M 270.172,200 L 270.172,374" fill="none" stroke="#475569" stroke-width="1.4" stroke-dasharray="5 3"/><g class="chart-point"><circle cx="270.172" cy="200" r="5.5" fill="#475569"/></g><text x="93.04" y="200" font-size="13" fill="#0F172A" text-anchor