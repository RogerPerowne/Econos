 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="740" height="586" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="58" y1="516" x2="58" y2="21" stroke="#334155" stroke-width="2"/><polygon points="58,16 54,28 62,28" fill="#334155"/><line x1="58" y1="516" x2="711" y2="516" stroke="#334155" stroke-width="2"/><polygon points="716,516 704,512 704,520" fill="#334155"/><text x="48" y="530" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="58" y="11" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price / cost (£)</text><text x="716" y="534" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Output (Q)</text></g></g><g class="kdc-1"><path d="M 109.8,106.9L 382.0,209.8L 673.6,416.5" fill="none" stroke="#059669" stroke-width="2.6" clip-path="url(#econos-chart-clip)"/><text x="679.6" y="424.481" text-anchor="start" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">D</text></g><g class="kdc-1"><path d="M 382.0,516.0L 382.0,209.8" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="3 3" clip-path="url(#econos-chart-clip)"/></g><g class="kdc-1"><path d="M 58.0,209.8L 382.0,209.8" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="3 3" clip-path="url(#econos-chart-clip)"/></g><g class="kdc-2"><path d="M 109.8,126.4L 382.0,332.3" fill="none" stroke="#D97706" stroke-width="2" clip-path="url(#econos-chart-clip)"/><text x="376" y="324.25" text-anchor="end" font-size="13" font-weight="700" fill="#D97706" dominant-baseline="middle">MR</text></g><g class="kdc-2"><path d="M 382.0,439.