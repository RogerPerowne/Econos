ke-width="2" stroke-dasharray="5 3" clip-path="url(#econos-chart-clip-1)"/><path d="M 519.072,282 L 519.072,124.5" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 3"/><path d="M 412,124.5 L 519.072,124.5" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="519.0543157894737" cy="206.4" r="4" fill="#475569"/></g><g class="chart-point"><circle cx="519.072" cy="124.5202236631579" r="4.5" fill="#059669"/></g><text x="408.08" y="124.5" font-size="12" fill="#0F172A" text-anchor="end" font-weight="700">P_B</text><text x="519.072" y="297.12" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Q_B</text><text x="465.536" y="203.25" font-size="12" fill="#D97706" text-anchor="middle" font-weight="700">Revenue</text><text x="652.8" y="220.26" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">MC</text><text x="360" y="311" font-size="12" fill="#0F172A" text-anchor="middle" font-style="italic">P_B > P_A and Q_A > Q_B — inelastic buyers pay more for fewer units (MR_A = MR_B = MC)</text></svg>"`;

