urple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="460" height="328" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="56" y1="284" x2="56" y2="15" stroke="#334155" stroke-width="2"/><polygon points="56,10 52,22 60,22" fill="#334155"/><line x1="56" y1="284" x2="435" y2="284" stroke="#334155" stroke-width="2"/><polygon points="440,284 428,280 428,288" fill="#334155"/><text x="46" y="298" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="56" y="5" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price level (P)</text><text x="440" y="302" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Real output (Y)</text></g></g><g class="idl-1"><rect x="70.96000000000001" y="115.03999999999999" width="112.2" height="19.008" rx="5" fill="#05966914" stroke="#05966950"/></g><g class="idl-2"><rect x="295.36" y="252.32" width="112.2" height="19.008" rx="5" fill="#D9770614" stroke="#D9770650"/></g><path d="M 78.4,239.1C 142.0,227.2,205.6,211.4,258.0,183.7" fill="none" stroke="#059669" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/><path d="M 258.0,183.7C 310.3,146.7,355.2,99.2,396.3,35.8" fill="none" stroke="#D97706" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/><text x="404.34000000000003" y="33.84" text-anchor="start" font-size="13" font-weight="700" fill="#D97706" dominant-baseline="middle">SRAS</text><g class="idl-1"><line x1="56" y1="216.37112105703017" x2="175.68" y2="216.37112105703017" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/><line x1="175.68" y1="284" x2="175.68" y2="216.37112105703017" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/><text x="46" y="220.37112105703017" font-size="12" font-weight="700" fill="#059669" text-anchor="middle">P₁</text><text x="175.68" y="301" font-size="12" font-weight="700" fill="#059669" tex