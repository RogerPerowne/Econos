 text-anchor="middle" font-weight="700">Profit</text></g><g class="nm-3"><text x="493.88888888888886" y="421.1" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q₃</text></g><g class="nm-3"><text x="486.31388888888887" y="300.53125" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">loss</text></g><g class="nm-4"><text x="361.07349703407607" y="421.1" font-size="12" fill="#2563EB" text-anchor="middle" font-weight="700">Q₂</text></g><g class="nm-4"><text x="297.5" y="88.75999999999999" font-size="12" fill="#2563EB" text-anchor="middle" font-weight="700">P = AC: break-even (fair return)</text></g></svg>"`;

exports[`chart SVG regression > neg-externality-interactive.js renders unchanged SVG markup > ECONOS_NEG_EXTERNALITY_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="negext-svg" viewBox="0 -16 590 456" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D = MSB, MPC, MSC curves and Eₘ, E* points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D = MSB, MPC, MSC. Points: Eₘ at (0.47, 0.48), E* at (0.36, 0.59).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath><style>.econos-chart-legends .layer-legend-base,.econos-chart-legends .layer-legend-extension,.econos-chart-legends .layer-legend-shift,.econos-chart-legends .layer-legend-efficiency{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-base .econos-chart-legends .layer-legend-base{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-extension .econos-chart-legends .layer-legend-extension{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-shift .econos-chart-legends .layer-legend-shift{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-efficiency .econos-chart-legends .layer-legend-efficiency{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="590" height="456" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-dwl"><polygon points="239,190.084 295,150.10000000000002 295,230.068" fill="#FEE2E2" opacity="0.75"/></g><g class="layer-base-curves"><path d="M 100.0,90.1L 490.0,370.0" fill="none" stroke="#D97706" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="490" y="318.537" text-anchor="middle" font-size="13" font-weight="700" fill="#D97706" dominant-baseline="middle">D = MSB</text></g><g class="layer-base-curves"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="490" y="120.59900000000002" text-anchor="middle" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">MPC</text></g><g class="layer-msc"><path d="M 100.0,290.0L 490.0,10.2" fill="none" stroke="#2563EB" stroke-width="3" stroke-dasharray="9 5" clip-path="url(#econos-chart-clip)"/><text x="490" y="50.475" text-anchor="middle" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">MSC</text></g><g class="layer-market-eq"><path d="M 60,230.068 L 295,230.068" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><path d="M 295,230.068 L 295,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-mec"><path d="M 400,75.13 L 400,155.09799999999998" fill="none" stroke="#7C3AED" stroke-width="3"/></g><g class="layer-optimal"><path d="M 60,190.084 L 239,190.084" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-optimal"><path d="M 239,190.084 L 239,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><g class="chart-point"><circle cx="295" cy="230.068" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/><text x="307" y="226.068" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">Eₘ</text></g></g><g class="layer-optimal"><g class="chart-point"><circle cx="239" cy="190.084" r="7" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="239" y="174.084" font-size="13" font-weight="700" fill="#059669" text-anchor="middle" dominant-baseline="middle">E*</text></g></g><g class="layer-market-eq"><text x="46" y="230.068" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">Pₘ</text></g><g class="layer-market-eq"><text x="295" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Qₘ</text></g><g class="layer-mec"><text x="412.00000000000006" y="115.11399999999998" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">MEC</text></g><g class="layer-optimal"><text x="46" y="190.084" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P*</text></g><g class="layer-optimal"><text x="239" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-dwl"><text x="286.33333333333337" y="190.084" font-size="13" fill="#DC2626" text-anchor="middle" font-weight="700">DWL</text></g></svg><div class="econos-chart-legends"><div class="layer-legend-base"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">FREE MARKET OUTCOME</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MPC (supply) meets D = MSB (demand) at the market equilibrium Eₘ.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Output Qₘ · Price Pₘ</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">THE BLIND SPOT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">This price reflects only the firm's own cost – the harm done to third parties stays invisible.</div></div></div></div><div class="layer-legend-extension"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">MSC = MPC + MEC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSC stacks the cost imposed on third parties on top of the firm's private cost.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">THE GAP</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Vertical gap = MEC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The marginal external cost – pollution, noise, CO₂. Producers don't pay it, so they over-produce.</div></div></div></div><div class="layer-legend-shift"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">THE SOCIAL OPTIMUM</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Welfare is highest where MSC = MSB, at E* (Q*, P*).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">OPTIMUM vs MARKET</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Q* < Qₘ  and  P* > Pₘ</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Society wants less output at a higher price; the market over-produces by Qₘ − Q*.</div></div></div></div><div class="layer-legend-efficiency"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">DEADWEIGHT WELFARE LOSS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The red triangle between Q* and Qₘ – bounded above by MSC, below by MSB.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Each extra unit: MSC > MSB</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">THE FIX</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">A Pigouvian tax = MEC at Q* shifts MPC up to MSC and erases the loss.</div></div></div></div></div></div>"`;

exports[`chart SVG regression > output-gap-compare.js renders unchanged SVG markup > ECONOS_OUTPUT_GAP_COMPARE_SPEC 1`] = `"<svg class="output-gap-compare-svg econos-chart--wide" viewBox="0 -16 680 316" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with Potential (trend), Actual curves</title><desc id="econos-chart-desc">Time on x-axis, Real output on y-axis. Curves: Potential (trend), Actual.</desc><defs><clipPath id="econos-chart-clip-0"><rect x="48" y="30" width="262" height="210"/></clipPath><clipPath id="econos-chart-clip-1"><rect x="388" y="30" width="262" height="210"/></clipPath><clipPath id="econos-chart-clip-2"><rect x="0" y="274" width="680" height="18"/></clipPath><clipPath id="econos-chart-clip"><rect x="48" y="30" width="262" height="210"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker><marker id="ogc-gap-up" markerWidth="8" markerHeight="8" refX="4" refY="1" orient="auto"><polygon points="0,7 8,7 4,0" fill="#DC2626"/></marker><marker id="ogc-gap-down" markerWidth="8" markerHeight="8" refX="4" refY="7" orient="auto"><polygon points="0,1 8,1 4,8" fill="#DC2626"/></marker></defs><rect x="0" y="-16" width="680" height="316" fill="#FFFFFF" rx="12"/><line x1="340" y1="24" x2="340" y2="268" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="48" y1="240" x2="48" y2="25" stroke="#334155" stroke-width="2"/><polygon points="48,20 44,32 52,32" fill="#334155"/><line x1="48" y1="240" x2="315" y2="240" stroke="#334155" stroke-width="2"/><polygon points="320,240 308,236 308,244" fill="#334155"/><text x="38" y="254" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="48" y="15" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Real output</text><text x="320" y="258" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Time</text></g></g><text x="179" y="18" font-size="12" font-weight="800" fill="#2563EB" text-anchor="middle">Output gap (recession)</text><path d="M 61.1,177.0L 296.9,67.8" fill="none" stroke="#059669" stroke-width="2.4" stroke-dasharray="6 4" clip-path="url(#econos-chart-clip-0)"/><text x="294.9" y="57.80000000000001" text-anchor="end" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">Potential (trend)</text><path d="M 61.1,177.0C 116.1,156.0,152.8,158.1,184.2,153.9C 220.9,147.6,262.8,118.2,296.9,101.4" fill="none" stroke="#2563EB" stroke-width="2.6" clip-path="url(#econos-chart-clip-0)"/><text x="300.9" y="115.4" text-anchor="end" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">Actual</text><path d="M 210.44,144.45 L 210.44,108.96000000000001" fill="none" stroke="#DC2626" stroke-width="1.8" marker-start="url(#ogc-gap-down)" marker-end="url(#ogc-gap-up)"/><text x="213.06" y="164.4" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Negative gap</text><g class="layer-axes"><g class="chart-axes"><line x1="388" y1="240" x2="388" y2="25" stroke="#334155" stroke-width="2"/><polygon points="388,20 384,32 392,32" fill="#334155"/><line x1="388" y1="240" x2="655" y2="240" stroke="#334155" stroke-width="2"/><polygon points="660,240 648,236 648,244" fill="#334155"/><text x="378" y="254" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="388" y="15" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Real output</text><text x="660" y="258" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Time</text></g></g><text x="519" y="18" font-size="12" font-weight="800" fill="#059669" text-anchor="middle">Output gap (at or near trend)</text><path d="M 401.1,177.0L 636.9,67.8" fill="none" stroke="#059669" stroke-width="2.4" stroke-dasharray="6 4" clip-path="url(#econos-chart-clip-1)"/><text x="634.9" y="57.80000000000001" text-anchor="end" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">Potential (trend)</text><path d="M 401.1,178.1C 471.8,145.5,540.0,114.0,636.9,74.1" fill="none" stroke="#2563EB" stroke-width="2.6" clip-path="url(#econos-chart-clip-1)"/><text x="640.9" y="88.1" text-anchor="end" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">Actual</text><text x="519" y="212.7" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Gap ≈ 0</text><text x="340" y="283" font-size="12" fill="#0F172A" text-anchor="middle" font-style="italic">Same trend — a cyclical gap fades with recovery; a structural deficit does not</text></svg>"`;

exports[`chart SVG regression > pc-efficiency.js renders unchanged SVG markup > ECONOS_PC_EFFICIENCY_SPEC 1`] = `"<svg class="firm-cost-revenue-svg" viewBox="0 -16 577 460" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with MC, AC, AR = MR = P curves</title><desc id="econos-chart-desc">Output (Q) on x-axis, Price / cost (£) on y-axis. Curves: MC, AC, AR = MR = P.</desc><defs><clipPath id="econos-chart-clip"><rect x="45" y="20" width="505" height="382"/></clipPath><style>.pcef-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.pcef-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.pcef-3{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .pcef-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .pcef-1,.sv-show-2 .pcef-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-3 .pcef-1,.sv-show-3 .pcef-2,.sv-show-3 .pcef-3{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="577" height="460" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="45" y1="402" x2="45" y2="15" stroke="#334155" stroke-width="2"/><polygon points="45,10 41,22 49,22" fill="#334155"/><line x1="45" y1="402" x2="555" y2="402" stroke="#334155" stroke-width="2"/><polygon points="560,402 548,398 548,406" fill="#334155"/><text x="35" y="416" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="45" y="5" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price / cost (£)</text><text x="560" y="420" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Output (Q)</text></g></g><polygon points="45,240.65524144653045 334.1623627468082,240.65524144653045 334.1623627468082,240.6552414465327 45,240.6552414465327" fill="#DC262633" opacity="0.22"/><g class="pcef-3"><path d="M 45.0,240.7L 334.2,240.7" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 4" clip-path="url(#econos-chart-clip)"/></g><g class="pcef-3"><path d="M 334.2,402.0L 334.2,240.7" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 4" clip-path="url(#econos-chart-clip)"/></g><g class="pcef-1"><path d="M 130.4,302.4L 137.3,306.7L 144.2,310.6L 151.1,314.1L 157.9,317.0L 164.8,319.6L 171.7,321.7L 178.5,323.3L 185.3,324.5L 192.2,325.3L 199.1,325.6L 205.9,325.4L 212.8,324.9L 219.7,323.8L 226.5,322.4L 233.4,320.4L 240.3,318.0L 247.2,315.2L 254.0,312.0L 260.8,308.3L 267.7,304.1L 274.6,299.5L 281.4,294.4L 288.3,288.9L 295.2,283.0L 302.0,276.6L 308.9,269.7L 315.8,262.4L 322.6,254.7L 329