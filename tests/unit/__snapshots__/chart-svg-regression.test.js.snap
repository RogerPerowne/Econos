ass="de-1"><path d="M 96.4,123.0C 184.7,268.2,276.9,268.2,403.6,141.4" fill="none" stroke="#059669" stroke-width="2.6" clip-path="url(#econos-chart-clip)"/></g><g class="de-1"><path d="M 150.16,152 L 150.16,199.51999999999998" fill="none" stroke="#059669" stroke-width="1.8" marker-end="url(#econos-arrow-green)"/></g><g class="de-1"><path d="M 349.84000000000003,146.72 L 349.84000000000003,194.24" fill="none" stroke="#059669" stroke-width="1.8" marker-end="url(#econos-arrow-green)"/></g><g class="de-2"><path d="M 250,175.76 L 250,223.28" fill="none" stroke="#D97706" stroke-width="2" marker-end="url(#econos-arrow-amber)"/></g><g class="de-2"><g class="chart-point"><circle cx="250" cy="170.54683572093637" r="5" fill="#FFFFFF" stroke="#2563EB" stroke-width="2.5"/></g></g><g class="de-2"><line x1="58" y1="233.90683572093639" x2="250" y2="233.90683572093639" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/><line x1="250" y1="284" x2="250" y2="233.90683572093639" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/><text x="250" y="301" font-size="12" font-weight="700" fill="#059669" text-anchor="middle">Q̄</text><g class="chart-point"><circle cx="250" cy="233.90683572093639" r="5" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/></g></g><g class="de-1"><text x="334.48" y="261.56" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">AC₂ (after innovation)</text></g><g class="de-1"><text x="248.07999999999998" y="37.85999999999998" font-size="12" font-weight="700" fill="#059669" text-anchor="middle">INNOVATION</text><text x="248.07999999999998" y="57.65999999999998" font-size="12" font-weight="700" fill="#059669" text-anchor="middle">AC shifts down</text></g><g class="de-2"><text x="144.39999999999998" y="229.92000000000002" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">SAME OUTPUT</text><text x="144.39999999999998" y="251.04000000000002" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">lower cost</text></g></svg>"`;

