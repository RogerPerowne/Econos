exports[`chart SVG regression > crowding-out.js renders unchanged SVG markup > ECONOS_CROWDING_OUT_SPEC 1`] = `"<svg class="crowding-out-svg" viewBox="0 -16 440 316" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with S, D₁, D₂ curves and E₁, E₂ points</title><desc id="econos-chart-desc">Loanable funds (Q) on x-axis, Real interest rate (r) on y-axis. Curves: S, D₁, D₂. Points: E₁ at (0.50, 0.48), E₂ at (0.57, 0.55).</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="26" width="358" height="246"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-1,.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}.idl-old-solid{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-1 .idl-old-solid,.sv-show-2 .idl-old-solid{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY