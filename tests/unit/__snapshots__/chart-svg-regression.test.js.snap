exports[`chart SVG regression > uk-productivity-puzzle.js renders unchanged SVG markup > ECONOS_UK_PRODUCTIVITY_PUZZLE_SPEC 1`] = `"<svg class="uk-productivity-puzzle-svg" viewBox="0 -16 720 376" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with Pre-crisis trend, Actual path curves</title><desc id="econos-chart-desc">Year on x-axis, Output per hour on y-axis. Curves: Pre-crisis trend, Actual path.</desc><defs><clipPath id="econos-chart-clip"><rect x="70" y="36" width="600" height="250"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="720" height="376" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="70" y1="286" x2="70" y2="31" stroke="#334155" stroke-width="2"/><polygon points="70,26 66,38 74,38" fill="#334155"/><line x1="70" y1="286" x2="675" y2="286" stroke="#334155" stroke-width="2"/><polygon points="680,286 668,282 668,290" fill="#334155"/><text x="60" y="300" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="70" y="21" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Output per hour</text><text x="680" y="304" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Year</text></g></g><polygon points="269.8,176.06 670,56 670,141 269.8,176.06" fill="#EDE9FE" opacity="0.6"/><path d="M 70.0,236.0L 670.0,56.0" fill="none" stroke="#059669" stroke-width="2.4" stroke-dasharray="7 4" clip-path="url(#econos-chart-clip)"/><text x="662" y="46" text-anchor="end" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">Pre-crisis trend</text><path d="M 70.0,236.0L 269.8,176.1C 329.8,171.1,389.8,166.1,670.0,141.0" fill="none" stroke="#2563EB" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/><text x="662" y="155" text-anchor="end" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">Actual path</text><path d="M 269.8,286 L 269.8,36" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="269.8" cy="176.06" r="5" fill="#475569"/></g><text x="70" y="301" font-size="12" fill="#0F172A" text-anchor="middle">2000</text><text x="170.2" y="301" font-size="12" fill="#0F172A" text-anchor="middle">2004</text><text x="269.8" y="301" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">2008</text><text x="370" y="301" font-size="12" fill="#0F172A" text-anchor="middle">2012</text><text x="470.20000000000005" y="301" font-size="12" fill="#0F172A" text-anchor="middle">2016</text><text x="569.8" y="301" font-size="12" fill="#0F172A" text-anchor="middle">2020</text><text x="670" y="301" font-size="12" fill="#0F172A" text-anchor="middle">2024</text><text x="269.8" y="23.5" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700">Financial crisis</text><text x="490" y="106" font-size="13" fill="#7D23CB" text-anchor="middle" font-weight="700">Productivity gap</text><text x="490" y="121" font-size="12" fill="#7D23CB" text-anchor="middle" font-style="italic">(lost momentum)</text></svg>"`;

exports[`chart SVG regression > welfare-govt-failure-interactive.js renders unchanged SVG markup > ECONOS_WELFARE_GOVT_FAILURE_SPEC 1`] = `"<svg class="welfare-gf-svg" viewBox="0 -16 560 376" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with MPC, MSB, MSC, S + tax curves and E₁, E*, E'' points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: MPC, MSB, MSC, S + tax. Points: E₁ at (0.47, 0.48), E* at (0.36, 0.59), E'' at (0.33, 0.62).</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="30" width="420" height="290"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-3{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-1,.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-3 .idl-1,.sv-show-3 .idl-2,.sv-show-3 .idl-3{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate"