exports[`chart SVG regression > j-curve-interactive.js renders unchanged SVG markup > ECONOS_J_CURVE_INTERACTIVE_SPEC 1`] = `"<svg class="j-curve-interactive-svg" viewBox="0 -16 440 316" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Econos chart</title><desc id="econos-chart-desc">Time on x-axis, Current account on y-axis.</desc><defs><clipPath id="econos-chart-clip"><rect x="70" y="24" width="345" height="258"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-3{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-1,.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-3 .idl-1,.sv-show-3 .idl-2,.sv-show-3 .idl-3{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="440" height="316" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="70" y1="282" x2="70" y2="19" stroke="#334155" stroke-width="2"/><polygon points="70,14 66,26 74,26" fill="#334155"/><line x1="70" y1="282" x2="420" y2="282" stroke="#334155" stroke-width="2"/><polygon points="425,282 413,278 413,286" fill="#334155"/><text x="60" y="296" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="70" y="9" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Current account</text><text x="425" y="300" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Time</text></g></g><g class="idl-3"><rect x="240.085" y="61.926000000000016" width="165.6" height="33.54" rx="5" fill="#7C3AED14" stroke="#7C3AED50"/></g><path d="M 70.0,155.1L 415.0,155.1" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="5 4" clip-path="url(#econos-chart-clip)"/><path d="M 70.0,155.1L 110.0,155.1" fill="none" stroke="#475569" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><path d="M 110.0,108.9L 110.0,152.0" fill="none" stroke="#DC2626" stroke-width="1.5" stroke-dasharray="4 3" clip-path="url(#econos-chart-clip)"/><g class="idl-1"><path d="M 70.0,155.1L 110.0,155.1C 120.0,162.0,174.9,247.9,200.1,245.9" fill="none" stroke="#DC2626" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/></g><g class="idl-2"><path d="M 200.1,245.9C 220.1,244.1,262.2,196.1,290.1,155.1C 311.8,120.0,365.0,90.0,405.0,77.9" fill="none" stroke="#DC2626" stroke-width="2.8" clip-path="url(#econos-chart-clip)"/></g><g class="idl-3"><path d="M 110.0,155.1C 134.9,174.9,178.0,252.1,202.1,252.1C 228.0,252.1,300.1,258.0,410.2,255.9" fill="none" stroke="#7C3AED" stroke-width="2.2" stroke-dasharray="9 5" clip-path="url(#econos-chart-clip)"/></g><g class="idl-1"><g class="chart-point"><circle cx="200.065" cy="245.88" r="4.5" fill="#DC2626"/></g></g><g class="idl-2"><g class="chart-point"><circle cx="290.11" cy="155.06400000000002" r="4" fill="#DC2626"/></g></g><text x="63.1" y="76.88999999999999" font-size="12" fill="#059669" text-anchor="end" font-weight="700">Surplus +</text><text x="63.1" y="223.95" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">Deficit −</text><text x="113.47" y="103.98000000000002" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">devaluation</text><g class="idl-1"><text x="174.88" y="260.07" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">PED < 1 → CA worsens</text></g><g class="idl-2"><text x="354.96999999999997" y="116.88" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">PED > 1 → CA improves</text></g><g class="idl-2"><text x="248.02" y="183.95999999999998" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700" font-style="italic">J-curve</text></g><g class="idl-3"><text x="340.135" y="243.042" font-size="12" fill="#7D23CB" text-anchor="middle" font-weight="700">M-L fails: CA stays worse</text></g><g class="idl-3"><text x="322.885" y="74.31100000000002" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">Marshall-Lerner condition</text><text x="322.885" y="91.08100000000002" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">|PED_X| + |PED_M| > 1</text></g></svg>"`;

