rray="9 5" clip-path="url(#econos-chart-clip)"/><text x="452" y="34.15599999999995" font-size="13" font-weight="700" fill="#2563EB">MSC</text></g><g class="layer-market-eq"><path d="M 60,230.068 L 295,230.068" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><path d="M 295,230.068 L 295,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-mec"><path d="M 400,75.13 L 400,155.09799999999998" fill="none" stroke="#7C3AED" stroke-width="3"/></g><g class="layer-optimal"><path d="M 60,190.084 L 239,190.084" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-optimal"><path d="M 239,190.084 L 239,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><g class="chart-point"><circle cx="295" cy="230.068" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/><text x="307" y="226.068" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">E_market</text></g></g><g class="layer-optimal"><g class="chart-point"><circle cx="239" cy="190.084" r="7" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="239" y="174.084" font-size="13" font-weight="700" fill="#059669" text-anchor="middle" dominant-baseline="middle">E*</text></g></g><g class="layer-market-eq"><text x="46" y="230.068" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P_m</text></g><g class="layer-market-eq"><text x="295" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q_m</text></g><g class="layer-mec"><text x="412.00000000000006" y="115.11399999999998" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">MEC</text></g><g class="layer-optimal"><text x="46" y="190.084" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P*</text></g><g class="layer-optimal"><text x="239" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-dwl"><text x="286.33333333333337" y="190.084" font-size="13" fill="#DC2626" text-anchor="middle" font-weight="700">DWL</text></g><g class="layer-legend-base"><circle cx="176.7" cy="29.0" r="7" fill="#DC2626"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Free market equilibrium: MPC = MSB</text></g><g class="layer-legend-extension"><circle cx="107.1" cy="29.0" r="7" fill="#7C3AED"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Production imposes external costs → MSC sits above MPC</text></g><g class="layer-legend-shift"><circle cx="155.8" cy="29.0" r="7" fill="#059669"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Socially optimal output: where MSC = MSB</text></g><g class="layer-legend-efficiency"><circle cx="124.5" cy="29.0" r="7" fill="#DC2626"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Overproduction → deadweight welfare loss triangle</text></g></svg><div class="econos-chart-legends"><div class="layer-legend-base"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">FREE MARKET OUTCOME</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Producers maximise profit at</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MPC = MSB → equilibrium at</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">(Q_m, P_m).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">WHAT EACH CURVE MEANS</div><div class="econos-chart-legend__body" style="color:#D97706;font-weight:700;font-size:13px;">D = MSB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Marginal social benefit – value</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">to society of one more unit.</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">MPC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Marginal private cost – what</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">the firm itself pays.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">BUT THIS IGNORES…</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">External costs on third parties</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(pollution, congestion).</div></div></div></div><div class="layer-legend-extension"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">MSC = MPC + MEC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSC adds the cost imposed on</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">third parties to private cost.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Vertical gap = MEC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(marginal external cost)</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">EXAMPLES OF MEC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Air pollution from a factory</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Noise from late-night venues</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Congestion from extra cars</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">CO₂ emissions from cement</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">THE PROBLEM</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Producers don't pay MEC, so</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">they produce too much.</div></div></div></div><div class="layer-legend-shift"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">THE OPTIMUM</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Society maximises welfare</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">where MSC = MSB at</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">(Q*, P*).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">COMPARISON</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Q* < Q_m</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Society wants less output.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">P* > P_m</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Optimal price is higher.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">FREE MARKET FAILS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Without intervention the market</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">overproduces by (Q_m − Q*).</div></div></div></div><div class="layer-legend-efficiency"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">DEADWEIGHT WELFARE LOSS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Shaded triangle between Q*</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">and Q_m, bounded above by</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSC and below by MSB.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">For each over-produced unit:</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSC > MSB → society loses</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(MSC − MSB) of welfare.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">POLICY RESPONSE</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">A Pigouvian tax = MEC at Q*</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">internalises the externality</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">and eliminates the DWL.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">EXAM TECHNIQUE</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Label all six: D=MSB, MPC,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSC, E_m, E*, DWL.</div></div></div></div></div></div>"`;

exports[`chart SVG regression > pos-externality-interactive.js renders unchanged SVG markup > ECONOS_POS_EXTERNALITY_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="posext-svg" viewBox="0 -16 590 456" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D = MPB, MPC = MSC, MSB curves and E_market, E* points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D = MPB, MPC = MSC, MSB. Points: E_market at (0.37, 0.37), E* at (0.49, 0.49).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath><style>.econos-chart-legends .layer-legend-base,.econos-chart-legends .layer-legend-extension,.econos-chart-legends .layer-legend-shift,.econos-chart-legends .layer-legend-efficiency{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-base .econos-chart-legends .layer-legend-base{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-extension .econos-chart-legends .layer-legend-extension{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-shift .econos-chart-legends .layer-legend-shift{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-efficiency .econos-chart-legends .layer-legend-efficiency{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="590" height="456" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-wfg"><polygon points="244,266.839 303,223.999 244,196.86700000000002" fill="#DCFCE7" opacity="0.85"/></g><g class="layer-base-curves"><path d="M 100.0,200.1L 490.0,380.0" fill="none" stroke="#D97706" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="498" y="384.008" font-size="13" font-weight="700" fill="#D97706">D = MPB</text></g><g class="layer-base-curves"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="498" y="86.12400000000002" font-size="13" font-weight="700" fill="#059669">MPC = MSC</text></g><g class="layer-msb"><path d="M 100.0,130.1L 490.0,310.0" fill="none" stroke="#2563EB" stroke-width="3" stroke-dasharray="9 5" clip-path="url(#econos-chart-clip)"/><text x="498" y="314.036" font-size="13" font-weight="700" fill="#2563EB">MSB</text></g><g class="layer-market-eq"><path d="M 60,266.839 L 244,266.839" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><path d="M 244,266.839 L 244,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-meb"><path d="M 380,328.957 L 380,258.985" fill="none" stroke="#7C3AED" stroke-width="3"/></g><g class="layer-optimal"><path d="M 60,223.999 L 303,223.999" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-optimal"><path d="M 303,223.999 L 303,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><g class="chart-point"><circle cx="244" cy="266.839" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/><text x="256" y="262.839" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">E_market</text></g></g><g class="layer-optimal"><g class="chart-point"><circle cx="303" cy="223.999" r="7" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="303" y="207.999" font-size="13" font-weight="700" fill="#059669" text-anchor="middle" dominant-baseline="middle">E*</text></g></g><g class="layer-market-eq"><text x="46" y="266.839" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">P_m</text></g><g class="layer-market-eq"><text x="244" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Q_m</text></g><g class="layer-meb"><text x="392" y="293.971" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">MEB</text></g><g class="layer-optimal"><text x="46" y="223.999" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P*</text></g><g class="layer-optimal"><text x="303" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-wfg"><text x="273.6666666666667" y="229.235" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Welfare gain</text></g><g class="layer-legend-base"><circle cx="176.7" cy="29.0" r="7" fill="#DC2626"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Free market equilibrium: MPC = MPB</text></g><g class="layer-legend-extension"><circle cx="93.2" cy="29.0" r="7" fill="#7C3AED"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Consumption creates external benefits → MSB sits above MPB</text></g><g class="layer-legend-shift"><circle cx="155.8" cy="29.0" r="7" fill="#059669"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Socially optimal output: where MSB = MSC</text></g><g class="layer-legend-efficiency"><circle cx="124.5" cy="29.0" r="7" fill="#059669"/><text x="310.0" y="33.0" font-size="12" font-weight="700" fill="#0F172A" text-anchor="middle">Under-consumption → welfare gain triangle forgone</text></g></svg><div class="econos-chart-legends"><div class="layer-legend-base"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">FREE MARKET OUTCOME</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Consumers maximise utility at</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MPC = MPB → equilibrium at</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">(Q_m, P_m).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">WHAT EACH CURVE MEANS</div><div class="econos-chart-legend__body" style="color:#D97706;font-weight:700;font-size:13px;">D = MPB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Marginal private benefit – value to</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">the consumer of one more unit.</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">MPC = MSC</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Same private and social cost</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(no production externality).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">BUT THIS IGNORES…</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">External benefits to third parties</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(herd immunity, productivity).</div></div></div></div><div class="layer-legend-extension"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">MSB = MPB + MEB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSB adds the benefit enjoyed by</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">third parties to private benefit.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Vertical gap = MEB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(marginal external benefit)</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">EXAMPLES OF MEB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Herd immunity from vaccination</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Productivity from education</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Lower crime from schooling</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Pollination from beekeeping</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">THE PROBLEM</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Consumers don't capture MEB,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">so they consume too little.</div></div></div></div><div class="layer-legend-shift"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">THE OPTIMUM</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Society maximises welfare</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">where MSB = MSC at</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">(Q*, P*).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">COMPARISON</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Q* > Q_m</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Society wants more output.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">P* > P_m</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Optimal price is higher.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">FREE MARKET FAILS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Without intervention the market</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">under-produces by (Q* − Q_m).</div></div></div></div><div class="layer-legend-efficiency"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">WELFARE GAIN FORGONE</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Shaded triangle between Q_m</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">and Q*, bounded above by</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSB and below by MSC.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">For each unit Q_m → Q*:</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSB > MSC → society gains</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">(MSB − MSC) of welfare.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">POLICY RESPONSE</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">A Pigouvian subsidy = MEB at Q*</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">internalises the externality</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">and closes the wedge.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">EXAM TECHNIQUE</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Label all six: D=MPB, MPC=MSC,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSB, E_m, E*, welfare gain.</div></div></div></div></div></div>"`;

exports[`chart SVG regression > ppf-big-picture.js renders unchanged SVG markup > ECONOS_PPF_BIGPIC_SPEC 1`] = `"<svg class="ppf-svg" viewBox="0 -16 440 376" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Econos chart</title><desc id="econos-chart-desc">Consumer goods on x-axis, Capital goods on y-axis. Points: A, B at (0.26, 0.30), C at (0.74, 0.66).</desc><defs><clipPath id="econos-chart-clip"><rect x="58" y="46" width="330" height="264"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="440" height="376" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="58" y1="310" x2="58" y2="41" stroke="#334155" stroke-width="2"/><polygon points="58,36 54,48 62,48" fill="#334155"/><line x1="58" y1="310" x2="393" y2="310" stroke="#334155" stroke-width="2"/><polygon points="398,310 386,306 386,314" fill="#334155"/><text x="48" y="324" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="58" y="31" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Capital goods</text><text x="398" y="328" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Consumer goods</text></g></g><path d="M 58.0,67.1C 196.6,67.1,361.6,199.1,361.6,299.4" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><g class="chart-point"><circle cx="209.8" cy="111.23835379450202" r="7" fill="#2563EB"/><text x="220.8" y="107.23835379450202" font-size="13" font-weight="700" fill="#2563EB" text-anchor="start" dominant-baseline="middle">A</text></g><g class="chart-point"><circle cx="143.8" cy="230.8" r="7" fill="#D97706"/><text x="154.8" y="226.8" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">B</text></g><g class="chart-point"><circle cx="302.2" cy="135.76" r="7" fill="#059669"/><text x="313.2" y="131.76" font-size="13" font-weight="700" fill="#059669" text-anchor="start" dominant-baseline="middle">C</text></g></svg>"`;

exports[`chart SVG regression > ppf-card1.js renders unchanged SVG markup > ECONOS_PPF_CARD1_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="ppf-svg" viewBox="0 -16 440 376" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂, PPF₃ curves and A, B, C, D, E, F, G, H points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂, PPF₃. Points: A at (0.46, 0.41), B at (0.24, 0.26), C at (0.67, 0.57), D at (0.25, 0.57), E at (0.60, 0.20), F at (0.46, 0.41), G at (0.34, 0.52), H at (0.23, 0.26).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="44" width="350" height="276"/></clipPath><style>.econos-chart-legends .layer-legend-base,.econos-chart-legends .layer-legend-extension,.econos-chart-legends .layer-legend-shift,.econos-chart-legends .layer-legend-efficiency{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-base .econos-chart-legends .layer-legend-base{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-extension .econos-chart-legends .layer-legend-extension{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-shift .econos-chart-legends .layer-legend-shift{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-efficiency .econos-chart-legends .layer-legend-efficiency{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker><marker id="ppf-occ-end" viewBox="0 0 8 6" markerWidth="6" markerHeight="6" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#D97706"/></marker><marker id="ppf-shift-out-end" viewBox="0 0 8 6" markerWidth="6" markerHeight="6" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#059669"/></marker><marker id="ppf-shift-out-start" viewBox="0 0 8 6" markerWidth="6" markerHeight="6" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#059669"/></marker><marker id="ppf-shift-in-end" viewBox="0 0 8 6" markerWidth="6" markerHeight="6" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#DC2626"/></marker><marker id="ppf-shift-in-start" viewBox="0 0 8 6" markerWidth="6" markerHeight="6" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#DC2626"/></marker></defs><rect x="0" y="-16" width="440" height="376" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="320" x2="60" y2="39" stroke="#334155" stroke-width="2"/><polygon points="60,34 56,46 64,46" fill="#334155"/><line x1="60" y1="320" x2="415" y2="320" stroke="#334155" stroke-width="2"/><polygon points="420,320 408,316 408,324" fill="#334155"/><text x="50" y="334" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="29" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="420" y="338" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="layer-ppf-base"><path d="M 60.0,142.5C 186.0,142.5,287.5,256.8,287.5,316.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="293.5" y="310.136" font-size="13" font-weight="700" fill="#2563EB">PPF₁</text></g><g class="layer-base-points"><line x1="60" y1="207.116" x2="221" y2="207.116" stroke="#94A3B8" stroke-width="1" stroke-dasharray="4 3"/><line x1="221" y1="320" x2="221" y2="207.116" stroke="#94A3B8" stroke-width="1" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="221" cy="207.116" r="7" fill="#2563EB"/><text x="232" y="222.116" font-size="13" font-weight="700" fill="#2563EB" text-anchor="start" dominant-baseline="middle">A</text></g><g class="chart-point"><circle cx="144" cy="249.06799999999998" r="7" fill="#D97706"/><text x="154" y="249.06799999999998" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">B</text></g><g class="chart-point"><circle cx="294.5" cy="162.40400000000002" r="7" fill="#DC2626"/><text x="304.5" y="162.40400000000002" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">C</text></g><text x="88" y="296.264" font-size="12" font-weight="600" fill="#D97706" font-style="italic" text-anchor="start">Inefficient zone</text><text x="319" y="126.80000000000001" font-size="12" font-weight="600" fill="#DC2626" font-style="italic" text-anchor="end">Unattainable zone</text></g><g class="layer-opp-cost"><path d="M 169.2,159.4 Q 235.0,137.8 261.2,248.2" fill="none" stroke="#D97706" stroke-width="1.6" stroke-dasharray="6 3" marker-end="url(#ppf-occ-end)"/><line x1="60" y1="161.57600000000002" x2="148.9" y2="161.57600000000002" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="148.9" y1="320" x2="148.9" y2="161.57600000000002" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="165.57600000000002" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">C₁</text><text x="148.9" y="337" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">K₁</text><g class="chart-point"><circle cx="148.9" cy="161.57600000000002" r="7" fill="#D97706"/><text x="158.9" y="152.57600000000002" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">D</text></g><line x1="60" y1="263.972" x2="270" y2="263.972" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><line x1="270" y1="320" x2="270" y2="263.972" stroke="#D97706" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="267.972" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">C₂</text><text x="270" y="337" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">K₂</text><g class="chart-point"><circle cx="270" cy="263.972" r="7" fill="#D97706"/><text x="280" y="254.97199999999998" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">E</text></g><text x="49.5" y="212.636" font-size="12" fill="#D97706" text-anchor="end" font-weight="700">−ΔC</text><text x="209.45" y="333.8" font-size="12" fill="#D97706" text-anchor="middle" font-weight="700">+ΔK</text></g><g class="layer-shift-curves"><path d="M 60.0,142.5C 186.0,142.5,287.5,256.8,287.5,316.1" fill="none" stroke="#2563EB" stroke-width="2" stroke-dasharray="9 5" opacity="0.55" clip-path="url(#econos-chart-clip)"/><path d="M 60.0,95.3C 214.0,95.3,340.0,249.1,340.0,316.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="346" y="310.136" font-size="13" font-weight="700" fill="#2563EB">PPF₂</text><path d="M 60.0,193.9C 140.5,193.9,228.0,280.5,228.0,316.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="234" y="310.136" font-size="13" font-weight="700" fill="#2563EB">PPF₃</text><path d="M 244.7,210.6 L 259.5,201.2" fill="none" stroke="#059669" stroke-width="1.8" stroke-linecap="round" marker-start="url(#ppf-shift-out-start)" marker-end="url(#ppf-shift-out-end)"/><path d="M 170.3,187.4 L 150.3,208.3" fill="none" stroke="#DC2626" stroke-width="1.8" stroke-linecap="round" marker-start="url(#ppf-shift-in-start)" marker-end="url(#ppf-shift-in-end)"/><text x="277" y="137.84" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Outward</text><text x="165" y="292.4" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Inward</text></g><g class="layer-efficiency"><line x1="60" y1="207.392" x2="221" y2="207.392" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="221" y1="320" x2="221" y2="207.392" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><g class="chart-point"><circle cx="221" cy="207.392" r="7" fill="#7C3AED"/><text x="232" y="222.392" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">F</text></g><g class="chart-point"><circle cx="179.7" cy="177.308" r="7" fill="#0891B2"/><text x="189.7" y="177.308" font-size="13" font-weight="700" fill="#0891B2" text-anchor="start" dominant-baseline="middle">G</text></g><g class="chart-point"><circle cx="140.5" cy="247.41199999999998" r="7" fill="#94A3B8"/><text x="129.5" y="236.41199999999998" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end" dominant-baseline="middle">H</text></g></g></svg><div class="econos-chart-legends"><div class="layer-legend-base"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#2563EB;">A · on the curve</strong> — efficient, no waste.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#D97706;">B · inside</strong> — resources lie idle.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#DC2626;">C · outside</strong> — not possible with today’s resources.</div></div></div></div><div class="layer-legend-extension"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#D97706;">Moving D → E:</strong> gain capital goods, lose consumer goods.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">That sacrifice is the <strong style="color:#D97706;">opportunity cost</strong>.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The bowed curve means it rises as you specialise.</div></div></div></div><div class="layer-legend-shift"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#059669;">PPF₂ · outward</strong> — more capacity (better tech, more resources).</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#DC2626;">PPF₃ · inward</strong> — lost capacity (war, disaster, depreciation).</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Moving along one curve is reallocation, not growth.</div></div></div></div><div class="layer-legend-efficiency"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Any point on the curve (like <strong style="color:#7C3AED;">F</strong>) is productively efficient.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Only <strong style="color:#0891B2;">G</strong> is allocatively efficient — what society wants most.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;"><strong style="color:#64748B;">H · inside</strong> the curve wastes resources.</div></div></div></div></div></div>"`;

exports[`chart SVG regression > ppf-card2.js renders unchanged SVG markup > ECONOS_PPF_CARD2_SPEC 1`] = `"<svg class="econos-chart" viewBox="0 -16 440 316" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF curves</title><desc id="econos-chart-desc">Good B on x-axis, Good A on y-axis. Curves: PPF.</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="30" width="340" height="238"/></clipPath><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker><marker id="ppfboi-ax"  markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#475569"/></marker><marker id="ppfboi-sac" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#DC2626"/></marker><marker id="ppfboi-gn"  markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><polygon points="0 0,7 3.5,0 7" fill="#059669"/></marker></defs><rect x="0" y="-16" width="440" height="316" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="55" y1="268" x2="55" y2="25" stroke="#334155" stroke-width="2"/><polygon points="55,20 51,32 59,32" fill="#334155"/><line x1="55" y1="268" x2="400" y2="268" stroke="#334155" stroke-width="2"/><polygon points="405,268 393,264 393,272" fill="#334155"/><text x="45" y="282" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="55" y="15" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Good A</text><text x="405" y="286" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Good B</text></g></g><path d="M 55.0,84.3C 242.0,84.3,395.0,256.1,395.0,268.0" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="401" y="262" font-size="13" font-weight="700" fill="#2563EB">PPF</text><g class="idl-1" style="display:none"><line x1="162.16800000000006" y1="102.23014399999994" x2="192.7680000001811" y2="113.65357575713986" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="162.16800000000006" cy="102.23014399999994" r="4.5" fill="#2563EB"/><path d="M 168.2,102.2 L 190.8,102.2" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 192.8,104.2 L 192.8,111.7" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="108.16800000000006" y="78.23014399999994" width="48" height="18" rx="4" fill="#2563EB22"/><text x="132.16800000000006" y="91.23014399999994" font-size="12" font-weight="700" fill="#2563EB" text-anchor="middle">Low OC</text></g><g class="idl-2" style="display:none"><line x1="275.95112500000005" y1="158.42164649999998" x2="306.55112500010694" y2="180.12354541036046" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="275.95112500000005" cy="158.42164649999998" r="4.5" fill="#D97706"/><path d="M 282.0,158.4 L 304.6,158.4" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 306.6,160.4 L 306.6,178.1" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="206.95112500000005" y="134.42164649999998" width="63" height="18" rx="4" fill="#D9770622"/><text x="238.45112500000005" y="147.42164649999998" font-size="12" font-weight="700" fill="#D97706" text-anchor="middle">Rising OC</text></g><g class="idl-3" style="display:none"><line x1="356.9029999999999" y1="223.065124" x2="387.50300000003386" y2="255.977445501733" stroke="#94A3B8" stroke-width="1" stroke-dasharray="3 2"/><circle cx="356.9029999999999" cy="223.065124" r="4.5" fill="#DC2626"/><path d="M 362.9,223.1 L 385.5,223.1" fill="none" stroke="#059669" stroke-width="1.5" marker-end="url(#ppfboi-gn)"/><path d="M 387.5,225.1 L 387.5,254.0" fill="none" stroke="#DC2626" stroke-width="1.5" marker-end="url(#ppfboi-sac)"/><rect x="301.9029999999999" y="199.065124" width="49" height="18" rx="4" fill="#DC262622"/><text x="326.4029999999999" y="212.065124" font-size="12" font-weight="700" fill="#DC2626" text-anchor="middle">High OC</text></g></svg>"`;

exports[`chart SVG regression > ppf-card3.js renders unchanged SVG markup > ECONOS_PPF_CARD3_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="ppf-moves-svg" viewBox="0 -16 590 456" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with PPF₁, PPF₂, PPF₃ curves and D, E, X points</title><desc id="econos-chart-desc">Capital Goods on x-axis, Consumer Goods on y-axis. Curves: PPF₁, PPF₂, PPF₃. Points: D at (0.30, 0.55), E at (0.58, 0.25), X at (0.26, 0.23).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="50" width="500" height="350"/></clipPath><style>.econos-chart-legends .layer-legend-along,.econos-chart-legends .layer-legend-recovery,.econos-chart-legends .layer-legend-outward,.econos-chart-legends .layer-legend-inward{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-along .econos-chart-legends .layer-legend-along{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-recovery .econos-chart-legends .layer-legend-recovery{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-outward .econos-chart-legends .layer-legend-outward{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-inward .econos-chart-legends .layer-legend-inward{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker><marker id="ppfmv-along-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#7C3AED"/></marker><marker id="ppfmv-rec-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#D97706"/></marker><marker id="ppfmv-out-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#059669"/></marker><marker id="ppfmv-out-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#059669"/></marker><marker id="ppfmv-in-end" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto"><path d="M0,0 L0,6 L8,3 z" fill="#DC2626"/></marker><marker id="ppfmv-in-start" markerWidth="8" markerHeight="8" refX="2" refY="3" orient="auto"><path d="M8,0 L8,6 L0,3 z" fill="#DC2626"/></marker></defs><rect x="0" y="-16" width="590" height="456" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="45" stroke="#334155" stroke-width="2"/><polygon points="60,40 56,52 64,52" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="35" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Consumer Goods</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Capital Goods</text></g></g><g class="layer-ppf1"><path d="M 60.0,174.9C 240.0,174.9,385.0,319.9,385.0,395.1" fill="none" stroke="#2563EB" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="391" y="389.1" font-size="13" font-weight="700" fill="#2563EB">PPF₁</text></g><g class="layer-ppf2"><path d="M 60.0,115.1C 280.0,115.1,460.0,310.1,460.0,395.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="466" y="389.1" font-size="13" font-weight="700" fill="#059669">PPF₂</text></g><g class="layer-ppf3"><path d="M 60.0,240.0C 175.0,240.0,300.0,349.9,300.0,395.1" fill="none" stroke="#DC2626" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="306" y="389.1" font-size="13" font-weight="700" fill="#DC2626">PPF₃</text></g><g class="layer-along"><path d="M 224.0,207.7 Q 285.0,207.5 341.8,301.9" fill="none" stroke="#7C3AED" stroke-width="2" stroke-dasharray="6 3" marker-end="url(#ppfmv-along-end)"/><line x1="60" y1="207.85" x2="210" y2="207.85" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="210" y1="400" x2="210" y2="207.85" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="211.85" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">C₁</text><text x="210" y="417" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">K₁</text><g class="chart-point"><circle cx="210" cy="207.85" r="7" fill="#7C3AED"/><text x="220" y="198.85" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">D</text></g><line x1="60" y1="313.9" x2="349" y2="313.9" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><line x1="349" y1="400" x2="349" y2="313.9" stroke="#7C3AED" stroke-width="1" stroke-dasharray="4 3"/><text x="50" y="317.9" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">C₂</text><text x="349" y="417" font-size="12" font-weight="700" fill="#7D23CB" text-anchor="middle">K₂</text><g class="chart-point"><circle cx="349" cy="313.9" r="7" fill="#7C3AED"/><text x="359" y="304.9" font-size="13" font-weight="700" fill="#7D23CB" text-anchor="start" dominant-baseline="middle">E</text></g><text x="45" y="260.7" font-size="12" fill="#7D23CB" text-anchor="end" font-weight="700">−ΔC</text><text x="279.5" y="417.5" font-size="12" fill="#7D23CB" text-anchor="middle" font-weight="700">+ΔK</text></g><g class="layer-recovery"><path d="M 216.7,302.4 L 266.3,269.8" fill="none" stroke="#D97706" stroke-width="2.5" stroke-dasharray="7 4" marker-end="url(#ppfmv-rec-end)"/><g class="chart-point"><circle cx="190" cy="318.1" r="7" fill="#D97706"/><text x="200" y="318.1" font-size="13" font-weight="700" fill="#D97706" text-anchor="start" dominant-baseline="middle">X</text><text x="214" y="318.1" font-size="12" fill="#0F172A" text-anchor="start" dominant-baseline="middle">– Underemployment</text></g><text x="120" y="372" font-size="12" font-weight="600" fill="#D97706" font-style="italic" text-anchor="start">Inefficient zone</text></g><g class="layer-outward"><path d="M 301.8,249.3 L 331.0,230.9" fill="none" stroke="#059669" stroke-width="3" stroke-linecap="round" marker-start="url(#ppfmv-out-start)" marker-end="url(#ppfmv-out-end)"/></g><g class="layer-inward"><path d="M 249.0,244.3 L 208.7,275.2" fill="none" stroke="#DC2626" stroke-width="3" stroke-linecap="round" marker-start="url(#ppfmv-in-start)" marker-end="url(#ppfmv-in-end)"/></g></svg><div class="econos-chart-legends"><div class="layer-legend-along"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#7C3AED;"></span><span>Moving along the PPF: reallocation</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">WHAT HAPPENS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">D → E: produce more</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">+ capital goods (K)</div><div class="econos-chart-legend__body" style="color:#DC2626;font-weight:700;font-size:13px;">− consumer goods (C)</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The frontier does NOT move.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Existing resources are just</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">reallocated between uses.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">OPPORTUNITY COST</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Every step along the curve</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">has an opportunity cost –</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">the slope of the PPF at that point.</div></div></div></div><div class="layer-legend-recovery"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#D97706;"></span><span>Short-run recovery: X moves to PPF₁</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#D97706;">WHAT X REPRESENTS</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Inside the frontier:</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">unemployment, idle capacity,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">resources not fully used.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#D97706;">THE RECOVERY</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Demand rises → firms rehire,</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">spare capacity reactivated.</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">X moves onto PPF₁.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#D97706;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">PPF₁ itself does NOT shift.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">This is demand-side / SR growth.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The capacity ceiling is unchanged.</div></div></div></div><div class="layer-legend-outward"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#059669;"></span><span>Outward shift: long-run growth</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">CAUSES OF OUTWARD SHIFT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Better technology</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  More capital investment</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Population / labour growth</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Education and training</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊕  Improved infrastructure</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">This is supply-side growth.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Productive capacity permanently</div><div class="econos-chart-legend__body" style="color:#059669;font-weight:700;font-size:13px;">increases.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">RESULT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">Previously unattainable combinations</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">become achievable on PPF₂.</div></div></div></div><div class="layer-legend-inward"><div class="econos-chart-legend"><div class="econos-chart-legend__title"><span class="econos-chart-legend__dot" style="background:#DC2626;"></span><span>Inward shift: supply shock</span></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">CAUSES OF INWARD SHIFT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  War / conflict (destroys capital)</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  Natural disasters</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  "Brain drain" emigration</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  Capital depreciation</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">⊖  Disease / population decline</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">KEY POINT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Productive capacity falls.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Previously attainable combinations</div><div class="econos-chart-legend__body" style="color:#DC2626;font-weight:700;font-size:13px;">become unachievable.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">WHERE IT BITES</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">Most acute after sudden shocks:</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:12px;font-style:italic;">war, pandemic, major disaster.</div></div></div></div></div></div>"`;

