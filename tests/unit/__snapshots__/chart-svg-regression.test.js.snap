12" fill="none" stroke="#475569" stroke-width="1" stroke-dasharray="4 3"/></g><g class="layer-a"><g class="chart-point"><circle cx="160.362" cy="93.19600000000003" r="6" fill="#059669"/></g></g><g class="layer-b"><g class="chart-point"><circle cx="351" cy="226" r="6" fill="#D97706"/></g></g><g class="layer-c"><g class="chart-point"><circle cx="541.6379999999999" cy="358.804" r="6" fill="#7C3AED"/></g></g><g class="layer-a"><text x="176.382" y="74.596" font-size="15" fill="#059669" text-anchor="start" font-weight="700">A</text></g><g class="layer-a"><text x="361.68" y="114.39999999999998" font-size="13" fill="#059669" text-anchor="start" font-weight="700">Elastic (|PED| > 1)</text></g><g class="layer-a"><text x="361.68" y="134.86" font-size="12" fill="#059669" text-anchor="start">upper part of the curve</text></g><g class="layer-b"><text x="367.02000000000004" y="207.39999999999998" font-size="15" fill="#D97706" text-anchor="start" font-weight="700">B</text></g><g class="layer-b"><text x="404.4" y="207.39999999999998" font-size="13" fill="#D97706" text-anchor="start" font-weight="700">Unit elastic (|PED| = 1)</text></g><g class="layer-b"><text x="404.4" y="227.86" font-size="12" fill="#D97706" text-anchor="start">midpoint · TR is maximised</text></g><g class="layer-c"><text x="557.658" y="340.204" font-size="15" fill="#7D23CB" text-anchor="start" font-weight="700">C</text></g><g class="layer-c"><text x="244.2" y="315.28" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">Inelastic (|PED| < 1)</text></g><g class="layer-c"><text x="244.2" y="335.74" font-size="12" fill="#7D23CB" text-anchor="start">lower part of the curve</text></g></svg>"`;

exports[`chart SVG regression > pos-externality-interactive.js renders unchanged SVG markup > ECONOS_POS_EXTERNALITY_SPEC 1`] = `"<div class="econos-chart-wrap-below"><svg class="posext-svg" viewBox="0 -16 590 456" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D = MPB, MPC = MSC, MSB curves and Eₘ, E* points</title><desc id="econos-chart-desc">Q on x-axis, P on y-axis. Curves: D = MPB, MPC = MSC, MSB. Points: Eₘ at (0.37, 0.37), E* at (0.49, 0.49).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath><style>.econos-chart-legends .layer-legend-base,.econos-chart-legends .layer-legend-extension,.econos-chart-legends .layer-legend-shift,.econos-chart-legends .layer-legend-efficiency{opacity:0;pointer-events:none;transition:opacity .32s ease}.show-base .econos-chart-legends .layer-legend-base{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-extension .econos-chart-legends .layer-legend-extension{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-shift .econos-chart-legends .layer-legend-shift{opacity:1;pointer-events:auto;transition:opacity .32s ease}.show-efficiency .econos-chart-legends .layer-legend-efficiency{opacity:1;pointer-events:auto;transition:opacity .32s ease}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/></marker><marker id="econos-arrow-rose" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#E11D48"/></marker><marker id="econos-arrow-purple" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED"/></marker></defs><rect x="0" y="-16" width="590" height="456" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">P</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Q</text></g></g><g class="layer-wfg"><polygon points="244,266.839 303,223.999 244,196.86700000000002" fill="#DCFCE7" opacity="0.85"/></g><g class="layer-base-curves"><path d="M 100.0,200.1L 490.0,380.0" fill="none" stroke="#D97706" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="482" y="368.008" text-anchor="end" font-size="13" font-weight="700" fill="#D97706" dominant-baseline="middle">D = MPB</text></g><g class="layer-base-curves"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#059669" stroke-width="3" clip-path="url(#econos-chart-clip)"/><text x="482" y="102.12400000000002" text-anchor="end" font-size="13" font-weight="700" fill="#059669" dominant-baseline="middle">MPC = MSC</text></g><g class="layer-msb"><path d="M 100.0,130.1L 490.0,310.0" fill="none" stroke="#2563EB" stroke-width="3" stroke-dasharray="9 5" clip-path="url(#econos-chart-clip)"/><text x="498" y="314.036" font-size="13" font-weight="700" fill="#2563EB" dominant-baseline="middle">MSB</text></g><g class="layer-market-eq"><path d="M 60,266.839 L 244,266.839" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><path d="M 244,266.839 L 244,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-meb"><path d="M 380,328.957 L 380,258.985" fill="none" stroke="#7C3AED" stroke-width="3"/></g><g class="layer-optimal"><path d="M 60,223.999 L 303,223.999" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-optimal"><path d="M 303,223.999 L 303,400" fill="none" stroke="#059669" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-market-eq"><g class="chart-point"><circle cx="244" cy="266.839" r="6" fill="#FFFFFF" stroke="#DC2626" stroke-width="2.5"/><text x="256" y="262.839" font-size="13" font-weight="700" fill="#DC2626" text-anchor="start" dominant-baseline="middle">Eₘ</text></g></g><g class="layer-optimal"><g class="chart-point"><circle cx="303" cy="223.999" r="7" fill="#FFFFFF" stroke="#059669" stroke-width="2.5"/><text x="303" y="207.999" font-size="13" font-weight="700" fill="#059669" text-anchor="middle" dominant-baseline="middle">E*</text></g></g><g class="layer-market-eq"><text x="46" y="266.839" font-size="12" fill="#DC2626" text-anchor="end" font-weight="700">Pₘ</text></g><g class="layer-market-eq"><text x="244" y="417.85" font-size="12" fill="#DC2626" text-anchor="middle" font-weight="700">Qₘ</text></g><g class="layer-meb"><text x="392" y="293.971" font-size="13" fill="#7D23CB" text-anchor="start" font-weight="700">MEB</text></g><g class="layer-optimal"><text x="46" y="223.999" font-size="12" fill="#059669" text-anchor="end" font-weight="700">P*</text></g><g class="layer-optimal"><text x="303" y="417.85" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Q*</text></g><g class="layer-wfg"><text x="273.6666666666667" y="229.235" font-size="12" fill="#059669" text-anchor="middle" font-weight="700">Gain</text></g></svg><div class="econos-chart-legends"><div class="layer-legend-base"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#DC2626;">FREE MARKET OUTCOME</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">D = MPB (demand) meets MPC = MSC (supply) at the market equilibrium Eₘ.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Output Qₘ · Price Pₘ</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">THE BLIND SPOT</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Buyers value only their own benefit – the benefit spilling over to third parties is invisible.</div></div></div></div><div class="layer-legend-extension"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">MSB = MPB + MEB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">MSB stacks the benefit enjoyed by third parties on top of the buyer's private benefit.</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#7C3AED;">THE GAP</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Vertical gap = MEB</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The marginal external benefit – herd immunity, productivity. Buyers don't capture it, so they under-consume.</div></div></div></div><div class="layer-legend-shift"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">THE SOCIAL OPTIMUM</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Welfare is highest where MSB = MSC, at E* (Q*, P*).</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#94A3B8;">OPTIMUM vs MARKET</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Q* > Qₘ  and  P* > Pₘ</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">Society wants more output at a higher price; the market under-produces by Q* − Qₘ.</div></div></div></div><div class="layer-legend-efficiency"><div class="econos-chart-legend"><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">WELFARE GAIN FORGONE</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">The green triangle between Qₘ and Q* – bounded above by MSB, below by MSC.</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:700;font-size:13px;">Each missing unit: MSB > MSC</div></div><div class="econos-chart-legend__section"><div class="econos-chart-legend__header" style="color:#059669;">THE FIX</div><div class="econos-chart-legend__body" style="color:#0F172A;font-weight:400;font-size:13px;">A Pigouvian subsidy = MEB at Q* lifts consumption to Q* and closes the wedge.</div></div></div></div></div></div>"`;

