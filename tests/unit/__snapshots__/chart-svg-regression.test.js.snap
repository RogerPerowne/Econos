exports[`chart SVG regression > inflation-2022-ad-as.js renders unchanged SVG markup > ECONOS_INFLATION_2022_AD_AS_SPEC 1`] = `"<svg class="inflation-2022-ad-as-svg" viewBox="0 -16 640 356" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with LRAS, AD₀, SRAS₀, AD₁, SRAS₁, AD₂ curves and E₀, E₁, E₂ points</title><desc id="econos-chart-desc">Real output (Y) on x-axis, Price level (P) on y-axis. Curves: LRAS, AD₀, SRAS₀, AD₁, SRAS₁, AD₂. Points: E₀ at (0.43, 0.42), E₁ at (0.36, 0.59), E₂ at (0.29, 0.51).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="20" width="540" height="260"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-3{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-3 .idl-3{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox