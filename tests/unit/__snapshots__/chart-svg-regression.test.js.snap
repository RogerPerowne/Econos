exports[`chart SVG regression > disequilibrium-interactive.js renders unchanged SVG markup > ECONOS_DISEQUILIBRIUM_SPEC 1`] = `"<svg class="disequilibrium-svg" viewBox="0 0 900 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D, S curves and E points</title><desc id="econos-chart-desc">Quantity on x-axis, Price on y-axis. Curves: D, S. Points: E at (0.47, 0.48).</desc><defs><clipPath id="econos-chart-clip"><rect x="60" y="43" width="500" height="357"/></clipPath><marker id="dq-up" markerWidth="10" markerHeight="10" refX="3" refY="0" orient="auto"><path d="M0,6 L3,0 L6,6 z" fill="#2563EB"/></marker><marker id="dq-down" markerWidth="10" markerHeight="10" refX="3" refY="6" orient="auto"><path d="M0,0 L3,6 L6,0 z" fill="#D97706"/></marker></defs><rect width="900" height="440" fill="#FFFFFF" rx="12"/><line x1="595" y1="16" x2="595" y2="424" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="5 4"/><g class="layer-axes"><g class="chart-axes"><line x1="60" y1="400" x2="60" y2="38" stroke="#334155" stroke-width="2"/><polygon points="60,33 56,45 64,45" fill="#334155"/><line x1="60" y1="400" x2="565" y2="400" stroke="#334155" stroke-width="2"/><polygon points="570,400 558,396 558,404" fill="#334155"/><text x="50" y="414" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="60" y="28" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price</text><text x="570" y="418" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Quantity</text></g></g><g class="layer-demand"><path d="M 100.0,90.1L 490.0,370.0" fill="none" stroke="#2563EB" stroke-width="3.5" clip-path="url(#econos-chart-clip)"/><text x="496" y="364.012" font-size="13" font-weight="700" fill="#2563EB">D</text></g><g class="layer-supply"><path d="M 100.0,370.0L 490.0,90.1" fill="none" stroke="#D97706" stroke-width="3.5" clip-path="url(#econos-chart-clip)"/><text x="496" y="84.12400000000002" font-size="13" font-weight="700" fill="#D97706">S</text></g><g class="layer-e1"><path d="M 60,230.068 L 295,230.068" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-e1"><path d="M 295,230.068 L 295,400" fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="5 4"/></g><g class="layer-shortage"><path d="M 60,310.036 L 406,310.036" fill="none" stroke="#2563EB" stroke-width="2" stroke-dasharray="6 4"/></g><g class="layer-shortage"><path d="M 184,324.31600000000003 L 184,400" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 4"/></g><g class="layer-shortage"><path d="M 406,324.31600000000003 L 406,400" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 4"/></g><g class="layer-shortage"><path d="M 36,305.038 L 36,247.918" fill="none" stroke="#2563EB" stroke-width="2.5" marker-end="url(#dq-up)"/></g><g class="layer-surplus"><path d="M 60,150.10000000000002 L 406,150.10000000000002" fill="none" stroke="#D97706" stroke-width="2" stroke-dasharray="6 4"/></g><g class="layer-surplus"><path d="M 184,164.38000000000002 L 184,400" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 4"/></g><g class="layer-surplus"><path d="M 406,164.38000000000002 L 406,400" fill="none" stroke="#475569" stroke-width="1.2" stroke-dasharray="4 4"/></g><g class="layer-surplus"><path d="M 36,155.09799999999998 L 36,211.861" fill="none" stroke="#D97706" stroke-width="2.5" marker-end="url(#dq-down)"/></g><g class="layer-e1"><g class="chart-point"><circle cx="295" cy="230.068" r="6.5" fill="#475569"/><text x="307" y="220.068" font-size="13" font-weight="700" fill="#0F172A" text-anchor="start" dominant-baseline="middle">E</text></g></g><g class="layer-shortage"><g class="chart-point"><circle cx="184" cy="310.036" r="5.5" fill="#475569"/></g></g><g class="layer-shortage"><g class="chart-point"><circle cx="406" cy="310.036" r="5.5" fill="#475569"/></g></g><g class="layer-surplus"><g class="chart-point"><circle cx="184" cy="150.10000000000002" r="5.5" fill="#475569"/></g></g><g class="layer-surplus"><g class="chart-point"><circle cx="406" cy="150.10000000000002" r="5.5" fill="#475569"/></g></g><g class="layer-base"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#059669"/></g></g><g class="layer-shortage"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#2563EB"/></g></g><g class="layer-surplus"><g class="chart-point"><circle cx="74" cy="31.93300000000005" r="7" fill="#D97706"/></g></g><g class="layer-e1"><text x="46" y="230.068" font-size="13" fill="#0F172A" text-anchor="end" font-weight="700" font-style="italic">Pₑ</text></g><g class="layer-e1"><text x="295" y="417.85" font-size="13" fill="#0F172A" text-anchor="middle" font-weight="700" font-style="italic">Qₑ</text></g><g class="layer-base"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Market in equilibrium · supply meets demand at E</text></g><g class="layer-shortage"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Excess demand (shortage) · price rises towards Pₑ</text></g><g class="layer-surplus"><text x="90" y="36.93100000000004" font-size="12" fill="#0F172A" text-anchor="start">Excess supply (surplus) · price falls towards Pₑ</text></g><g class="layer-shortage"><text x="46" y="310.036" font-size="13" fill="#2563EB" text-anchor="end" font-weight="700" font-style="italic">P₁</text></g><g class="layer-shortage"><text x="184" y="421.42" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700" font-style="italic">Qs</text></g><g class="layer-shortage"><text x="406" y="421.42" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700" font-style="italic">Qd</text></g><g class="layer-shortage"><text x="295" y="332.17" font-size="13" fill="#2563EB" text-anchor="middle" font-weight="700">Shortage</text></g><g class="layer-surplus"><text x="46" y="150.10000000000002" font-size="13" fill="#D97706" text-anchor="end" font-weight="700" font-style="italic">P₂</text></g><g class="layer-surplus"><text x="184" y="421.42" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700" font-style="italic">Qd</text></g><g class="layer-surplus"><text x="406" y="421.42" font-size="12" fill="#0F172A" text-anchor="middle" font-weight="700" font-style="italic">Qs</text></g><g class="layer-surplus"><text x="295" y="125.82400000000001" font-size="13" fill="#D97706" text-anchor="middle" font-weight="700">Surplus</text></g><g class="layer-base"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#059669" letter-spacing="1.5">EQUILIBRIUM</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">At E: Qd = Qs.</text><text x="620" y="123" font-size="13" font-weight="600" fill="#0F172A">No shortage, no surplus.</text><text x="620" y="143" font-size="13" font-weight="600" fill="#0F172A">No tendency for price to change.</text><text x="620" y="172" font-size="12" font-weight="800" fill="#94A3B8" letter-spacing="1.5">DISTURB IT…</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">Tap "Excess demand" to see what</text><text x="620" y="223" font-size="13" font-weight="600" fill="#0F172A">happens below Pₑ.</text><text x="620" y="243" font-size="13" font-weight="600" fill="#0F172A">Tap "Excess supply" to see what</text><text x="620" y="263" font-size="13" font-weight="600" fill="#0F172A">happens above Pₑ.</text></g></g><g class="layer-shortage"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#2563EB" letter-spacing="1.5">EXCESS DEMAND</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">Price P₁ is below Pₑ.</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">Qd > Qs → shortage.</text><text x="620" y="143" font-size="13" font-weight="600" fill="#0F172A">Buyers compete for limited</text><text x="620" y="163" font-size="13" font-weight="600" fill="#0F172A">stock → bid the price up.</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">Rising price reduces Qd and</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">expands Qs → returns to E.</text></g></g><g class="layer-surplus"><g class="chart-legend"><text x="620" y="72" font-size="12" font-weight="800" fill="#D97706" letter-spacing="1.5">EXCESS SUPPLY</text><text x="620" y="103" font-size="13" font-weight="600" fill="#0F172A">Price P₂ is above Pₑ.</text><text x="620" y="123" font-size="13" font-weight="700" fill="#0F172A">Qs > Qd → surplus.</text><text x="620" y="143" font-size="13" font-weight="600" fill="#0F172A">Sellers with unsold stock cut</text><text x="620" y="163" font-size="13" font-weight="600" fill="#0F172A">prices to clear inventory.</text><text x="620" y="183" font-size="13" font-weight="600" fill="#0F172A">Falling price raises Qd and</text><text x="620" y="203" font-size="13" font-weight="600" fill="#0F172A">contracts Qs → returns to E.</text></g></g></svg>"`;

