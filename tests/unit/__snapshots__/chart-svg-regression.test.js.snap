exports[`chart SVG regression > disequilibrium-interactive.js renders unchanged SVG markup > ECONOS_DISEQUILIBRIUM_SPEC 1`] = `"<svg class="pd-diseq-svg" viewBox="0 -16 700 516" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with D, S curves and E points</title><desc id="econos-chart-desc">Quantity on x-axis, Price on y-axis. Curves: D, S. Points: E at (0.52, 0.49).</desc><defs><clipPath id="econos-chart-clip"><rect x="84" y="38" width="534" height="384"/></clipPath><style>.layer-base{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.layer-surplus{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.layer-short{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .layer-base{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .layer-surplus{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-3 .layer-short{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="econos-arrow-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#2563EB"/></marker><marker id="econos-arrow-amber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#D97706"/></marker><marker id="econos-arrow-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#059669"/></marker><marker id="econos-arrow-red" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#DC2626"/></marker><marker id="econos-arrow-slate" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M 0 0 L 10 5