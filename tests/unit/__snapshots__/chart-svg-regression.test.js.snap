exports[`chart SVG regression > sras-curve-static.js renders unchanged SVG markup > ECONOS_SRAS_CURVE_STATIC_SPEC 1`] = `"<svg class="sras-curve-static-svg" viewBox="0 0 440 300" xmlns="http://www.w3.org/2000/svg" font-family="Inter, sans-serif" role="img" aria-labelledby="econos-chart-title econos-chart-desc"><title id="econos-chart-title">Chart with SRAS curves and A, B points</title><desc id="econos-chart-desc">Real output (Y) on x-axis, Price level (P) on y-axis. Curves: SRAS. Points: A at (0.33, 0.34), B at (0.65, 0.63).</desc><defs><clipPath id="econos-chart-clip"><rect x="55" y="18" width="360" height="254"/></clipPath><style>.idl-1{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.idl-2{opacity:0;visibility:hidden;transition:opacity .35s ease-out,visibility 0s linear .35s}.sv-show-1 .idl-1{opacity:1;visibility:visible;transition:opacity .35s ease-out}.sv-show-2 .idl-1,.sv-show-2 .idl-2{opacity:1;visibility:visible;transition:opacity .35s ease-out}</style><marker id="srs-arr-blue" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#3B82F6"/></marker></defs><rect width="440" height="300" fill="#FFFFFF" rx="12"/><g class="layer-axes"><g class="chart-axes"><line x1="55" y1="272" x2="55" y2="13" stroke="#334155" stroke-width="2"/><polygon points="55,8 51,20 59,20" fill="#334155"/><line x1="55" y1="272" x2="420" y2="272" stroke="#334155" stroke-width="2"/><polygon points="425,272 413,268 413,276" fill="#334155"/><text x="45" y="286" font-size="12" fill="#0F172A" text-anchor="middle">O</text><text x="55" y="3" font-size="13" font-weight="700" fill="#0F172A" text-anchor="middle">Price level (P)</text><text x="425" y="290" font-size="13" font-weight="700" fill="#0F172A" text-anchor="end">Real output (Y)</text></g></g><path d="M 70.1,255.0L 390.2,44.9" fill="none" stroke="#2563EB" stroke-width="2.5" clip-path="url(#econos-chart-clip)"/><text x="384.16" y="38.9