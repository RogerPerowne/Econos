// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`dial-engine — gauge > snapshot of the inflation dial matches 1`] = `"<svg class="econos-gauge" viewBox="0 0 160 90" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="UK CPI inflation 2.8%, target 1.5–2.5%" style="width:100%;height:auto;display:block;"><path d="M 20.00 75.00 A 60 60 0 0 1 140.00 75.00" stroke="#FECACA" stroke-width="8" fill="none" stroke-linecap="round"/><path d="M 37.57 32.57 A 60 60 0 0 1 64.47 17.04" stroke="#16A34A" stroke-width="8" fill="none" stroke-linecap="round"/><line x1="80" y1="75" x2="73.73" y2="15.33" stroke="#0B1426" stroke-width="2.4" stroke-linecap="round"/><circle cx="80" cy="75" r="4" fill="#0B1426"/></svg>"`;
